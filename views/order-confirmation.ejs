<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-7">
      <div class="glass-card text-center">
        <div class="mb-4">
          <div class="success-icon mx-auto">
            <i class="bi bi-check-lg"></i>
          </div>
        </div>
        <h2 class="fw-bold text-primary">
          <%= t('order_placed') %>
        </h2>
        <p class="text-muted mb-4">
          <%= t('thank_you_order') %>
        </p>

        <div class="glass-card mb-4" style="background: rgba(7,137,48,0.05);">
          <div class="row g-3 text-start">
            <div class="col-sm-6">
              <div class="text-muted small">
                <%= t('order_number') %>
              </div>
              <div class="fw-bold">#<%= order._id.toString().slice(-8) %>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="text-muted small">
                <%= t('total_paid') %>
              </div>
              <div class="fw-bold text-primary h4"><%= (order.totalAmount) %>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="text-muted small">
                <%= t('status') %>
              </div>
              <span class="badge bg-success rounded-pill">
                <%= order.orderStatus %>
              </span>
            </div>
            <div class="col-sm-6">
              <div class="text-muted small">
                <%= t('payment') %>
              </div>
              <span class="badge bg-<%= order.paymentStatus === 'paid' ? 'success' : 'warning' %> rounded-pill">
                <%= order.paymentStatus %>
              </span>
            </div>
          </div>
        </div>

        <h6 class="fw-bold mb-3">
          <%= t('cart_items') %>
        </h6>
        <% order.items.forEach(item=> { %>
          <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
            <div class="d-flex align-items-center gap-2">
              <img src="<%= item.imageUrl %>" class="rounded-3" style="width:40px;height:40px;object-fit:cover;"
                onerror="this.src='https://images.unsplash.com/photo-1604329760661-e71dc83f8f26?w=100'">
              <span class="fw-semibold">
                <%= item.name %> <span class="text-muted">x<%= item.qty %></span>
              </span>
            </div>
            <span class="fw-bold text-primary"><%= (item.totalPrice) %></span>
          </div>
          <% }) %>

            <div class="d-flex gap-3 justify-content-center mt-4">
              <a href="/delivery/<%= order._id %>" class="btn btn-primary rounded-pill px-4">
                <i class="bi bi-geo-alt me-2"></i>
                <%= t('track_delivery') %>
              </a>
              <a href="/orders" class="btn btn-outline-primary rounded-pill px-4">
                <i class="bi bi-bag-check me-2"></i>
                <%= t('view_orders') %>
              </a>
            </div>
      </div>
    </div>
  </div>
</div>

<style>
  .success-icon {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary), var(--primary-dark));
    display: flex;
    align-items: center;
    justify-content: center;
    animation: scaleIn 0.6s ease;
  }

  .success-icon i {
    color: #fff;
    font-size: 2.5rem;
  }

  @keyframes scaleIn {
    from {
      transform: scale(0);
    }

    to {
      transform: scale(1);
    }
  }
</style>