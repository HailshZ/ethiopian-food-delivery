<div class="container py-4">
    <a href="/owner/dashboard" class="btn btn-outline-secondary rounded-pill mb-3"><i
            class="bi bi-arrow-left me-1"></i>Back to Dashboard</a>
    <h2 style="color: #078930;"><i class="bi bi-egg-fried me-2"></i>
        <%= dish ? 'Edit Dish' : 'Add New Dish' %>
    </h2>
    <p class="text-muted mb-4">Your dish will be submitted for admin approval before appearing on the menu.</p>

    <div class="card shadow-sm border-0" style="border-radius: 15px;">
        <div class="card-body p-4">
            <form action="<%= dish ? '/owner/dish/' + dish._id + '/edit' : '/owner/dish/add' %>" method="post">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Name (English) *</label>
                        <input type="text" name="name" class="form-control" required
                            value="<%= dish ? dish.name : '' %>">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Name (Amharic)</label>
                        <input type="text" name="nameAm" class="form-control" value="<%= dish ? dish.nameAm : '' %>">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Description (English) *</label>
                        <textarea name="description" class="form-control" rows="3"
                            required><%= dish ? dish.description : '' %></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Description (Amharic)</label>
                        <textarea name="descriptionAm" class="form-control"
                            rows="3"><%= dish ? dish.descriptionAm : '' %></textarea>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Price *</label>
                        <input type="number" name="price" class="form-control" step="0.01" min="1" required
                            value="<%= dish ? dish.price : '' %>">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Category</label>
                        <select name="category" class="form-select">
                            <% ['food','coffee','drink','appetizer','breakfast','dessert','combo'].forEach(c=> { %>
                                <option value="<%= c %>" <%=dish && dish.category===c ? 'selected' : '' %>><%=
                                        c.charAt(0).toUpperCase() + c.slice(1) %>
                                </option>
                                <% }) %>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Spice Level</label>
                        <select name="spiceLevel" class="form-select">
                            <option value="">None</option>
                            <option value="mild" <%=dish && dish.spiceLevel==='mild' ? 'selected' : '' %>>🌶 Mild
                            </option>
                            <option value="medium" <%=dish && dish.spiceLevel==='medium' ? 'selected' : '' %>>🌶🌶
                                Medium</option>
                            <option value="hot" <%=dish && dish.spiceLevel==='hot' ? 'selected' : '' %>>🌶🌶🌶 Hot
                            </option>
                            <option value="extra-hot" <%=dish && dish.spiceLevel==='extra-hot' ? 'selected' : '' %>
                                >🌶🌶🌶🌶 Extra Hot</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Image URL</label>
                        <input type="url" name="imageUrl" class="form-control" placeholder="https://..."
                            value="<%= dish ? dish.imageUrl : '' %>">
                    </div>
                </div>
                <div class="mt-4">
                    <button type="submit" class="btn btn-success rounded-pill px-4">
                        <i class="bi bi-send me-1"></i>
                        <%= dish ? 'Update & Re-submit' : 'Submit for Approval' %>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>