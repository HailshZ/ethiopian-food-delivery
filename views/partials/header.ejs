<header class="main-header" id="main-header">
  <div class="container">
    <nav class="navbar navbar-expand-lg">
      <a class="navbar-brand" href="/">
        <i class="bi bi-cup-hot-fill me-2"></i>AradawFood
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
        aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarMain">
        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
          <li class="nav-item">
            <a class="nav-link" href="/menu"><i class="bi bi-grid-3x3-gap me-1"></i>
              <%= t('menu') %>
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/meal-plans"><i class="bi bi-calendar-week me-1"></i>
              <%= t('meal_plans') %>
            </a>
          </li>
          <% if (session && session.userId) { %>
            <li class="nav-item">
              <a class="nav-link" href="/orders"><i class="bi bi-bag-check me-1"></i>
                <%= t('my_orders') %>
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/subscriptions"><i class="bi bi-arrow-repeat me-1"></i>
                <%= t('subscriptions') %>
              </a>
            </li>
          <% } %>
          <% if (session && session.isAdmin) { %>
            <li class="nav-item">
              <a class="nav-link text-warning" href="/admin"><i class="bi bi-speedometer2 me-1"></i>Admin</a>
            </li>
          <% } %>
        </ul>

        <ul class="navbar-nav align-items-center">
          <!-- Cart -->
          <li class="nav-item me-2">
            <a class="nav-link cart-link" href="/cart" id="cart-nav-link">
              <i class="bi bi-cart3"></i>
              <span id="cart-badge" class="cart-badge <%= session.cart && session.cart.totalQty > 0 ? '' : 'd-none' %>">
                <%= session.cart ? session.cart.totalQty : 0 %>
              </span>
            </a>
          </li>

          <!-- Language -->
          <li class="nav-item me-2">
            <form action="/language" method="post" class="d-inline">
              <select name="language" class="lang-select" onchange="this.form.submit()">
                <option value="en" <%= currentLanguage === 'en' ? 'selected' : '' %>>🇬🇧 EN</option>
                <option value="am" <%= currentLanguage === 'am' ? 'selected' : '' %>>🇪🇹 AM</option>
              </select>
            </form>
          </li>

          <% if (session && session.userId) { %>
            <!-- User dropdown -->
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle user-dropdown" href="#" role="button" data-bs-toggle="dropdown">
                <div class="user-avatar">
                  <%= session.userName ? session.userName.charAt(0).toUpperCase() : 'U' %>
                </div>
                <span class="d-none d-lg-inline ms-1">
                  <%= session.userName %>
                </span>
              </a>
              <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-4">
                <li><a class="dropdown-item" href="/profile"><i class="bi bi-person me-2"></i>
                    <%= t('profile') %>
                  </a></li>
                <li><a class="dropdown-item" href="/orders"><i class="bi bi-bag-check me-2"></i>
                    <%= t('my_orders') %>
                  </a></li>
                <li><a class="dropdown-item" href="/subscriptions"><i class="bi bi-arrow-repeat me-2"></i>
                    <%= t('subscriptions') %>
                  </a></li>
                <% if (session.isAdmin) { %>
                  <li>
                    <hr class="dropdown-divider">
                  </li>
                  <li><a class="dropdown-item text-warning" href="/admin"><i class="bi bi-speedometer2 me-2"></i>Admin
                      Panel</a></li>
                <% } %>
                <li>
                  <hr class="dropdown-divider">
                </li>
                <li><a class="dropdown-item text-danger" href="/logout"><i class="bi bi-box-arrow-right me-2"></i>
                    <%= t('logout') %>
                  </a></li>
              </ul>
            </li>
          <% } else { %>
            <li class="nav-item">
              <a class="nav-link" href="/login"><i class="bi bi-box-arrow-in-right me-1"></i>
                <%= t('login') %>
              </a>
            </li>
            <li class="nav-item">
              <a class="btn btn-accent btn-sm rounded-pill px-3 ms-2" href="/register">
                <%= t('register') %>
              </a>
            </li>
          <% } %>
        </ul>
      </div>
    </nav>
  </div>
</header>