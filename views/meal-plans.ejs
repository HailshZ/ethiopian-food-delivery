<div class="container py-5">
    <div class="section-header text-center mb-5">
        <h1 class="section-title"><i class="bi bi-calendar-week me-2"></i>
            <%= t('meal_plans') %>
        </h1>
        <p class="text-muted">Subscribe to weekly or monthly plans and save time & money</p>
        <div class="section-divider"></div>
    </div>

    <% if (!plans || plans.length===0) { %>
        <div class="empty-state">
            <i class="bi bi-calendar-x"></i>
            <h4>No meal plans available yet</h4>
            <p>Check back soon for our curated meal plans!</p>
        </div>
        <% } else { %>
            <div class="row g-4">
                <% plans.forEach(plan=> { %>
                    <div class="col-md-6 col-lg-4">
                        <div class="plan-card">
                            <div class="plan-card-header">
                                <span class="plan-duration-badge">
                                    <%= plan.duration %>
                                </span>
                                <h4>
                                    <%= currentLanguage==='en' ? plan.name : (plan.nameAm || plan.name) %>
                                </h4>
                                <div class="plan-price">
                                    $<%= plan.price.toFixed(2) %>
                                        <span>/<%= plan.duration==='weekly' ? 'week' : 'month' %></span>
                                </div>
                            </div>
                            <div class="plan-card-body">
                                <p class="text-muted mb-4">
                                    <%= currentLanguage==='en' ? plan.description : (plan.descriptionAm ||
                                        plan.description) %>
                                </p>
                                <h6 class="mb-3"><i class="bi bi-calendar3 me-1"></i> Weekly Schedule</h6>
                                <div class="plan-schedule">
                                    <% const
                                        days=['monday','tuesday','wednesday','thursday','friday','saturday','sunday'];
                                        %>
                                        <% const dayLabels=['Mon','Tue','Wed','Thu','Fri','Sat','Sun']; %>
                                            <% days.forEach((day, i)=> { %>
                                                <% if (plan.meals[day] && plan.meals[day].length> 0) { %>
                                                    <div class="schedule-day">
                                                        <span class="day-label">
                                                            <%= dayLabels[i] %>
                                                        </span>
                                                        <div class="day-meals">
                                                            <% plan.meals[day].forEach(slot=> { %>
                                                                <span class="meal-tag">
                                                                    <%= slot.dish ? (currentLanguage==='en' ?
                                                                        slot.dish.name : (slot.dish.nameAm ||
                                                                        slot.dish.name)) : 'TBD' %>
                                                                </span>
                                                                <% }) %>
                                                        </div>
                                                    </div>
                                                    <% } %>
                                                        <% }) %>
                                </div>
                            </div>
                            <div class="plan-card-footer">
                                <a href="/meal-plans/<%= plan.id %>" class="btn btn-primary w-100 rounded-pill">
                                    <i class="bi bi-eye me-1"></i> View Details & Subscribe
                                </a>
                            </div>
                        </div>
                    </div>
                    <% }) %>
            </div>
            <% } %>
</div>