<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<div class="container py-5">
  <h1 class="fw-bold mb-5 text-center" style="color: #078930;">
    <%= t('checkout') %>
  </h1>

  <div id="cart-data" data-cart='<%- JSON.stringify(cart.items) %>' style="display: none;"></div>

  <div class="row g-4">
    <!-- Shipping Address Form -->
    <div class="col-lg-8">
      <div class="card border-0 shadow-lg" style="border-radius: 30px;">
        <div class="card-header text-white py-3 px-4"
          style="background: linear-gradient(135deg, #078930 0%, #056b24 100%); border-radius: 30px 30px 0 0;">
          <h5 class="mb-0"><i class="bi bi-truck me-2"></i>
            <%= t('shipping_address') %>
          </h5>
        </div>
        <div class="card-body p-5">
          <form id="shipping-form">
            <div class="mb-4">
              <label class="form-label fw-semibold text-secondary">
                <%= t('street_address') %>
              </label>
              <div class="input-group">
                <span class="input-group-text bg-white border-end-0" style="border-color: #ced4da;"><i
                    class="bi bi-house-door-fill" style="color: #078930;"></i></span>
                <input type="text" class="form-control border-start-0 ps-0" id="street" name="street" required>
              </div>
            </div>
            <div class="row">
              <div class="col-md-6 mb-4">
                <label class="form-label fw-semibold text-secondary">
                  <%= t('city') %>
                </label>
                <div class="input-group">
                  <span class="input-group-text bg-white border-end-0"><i class="bi bi-building"
                      style="color: #078930;"></i></span>
                  <input type="text" class="form-control border-start-0 ps-0" id="city" name="city" required>
                </div>
              </div>
              <div class="col-md-6 mb-4">
                <label class="form-label fw-semibold text-secondary">
                  <%= t('zip_code') %>
                </label>
                <div class="input-group">
                  <span class="input-group-text bg-white border-end-0"><i class="bi bi-mailbox"
                      style="color: #078930;"></i></span>
                  <input type="text" class="form-control border-start-0 ps-0" id="zipCode" name="zipCode" required>
                </div>
              </div>
            </div>

            <!-- Delivery Location Map -->
            <div class="mb-4">
              <label class="form-label fw-semibold text-secondary"><i class="bi bi-geo-alt-fill me-1"
                  style="color: #078930;"></i>Delivery Location</label>
              <p class="text-muted small mb-2">Click on the map to set your delivery location. Delivery fee is
                calculated based on distance.</p>
              <div id="delivery-map" style="height: 280px; border-radius: 15px; border: 2px solid #dee2e6; z-index: 1;">
              </div>
              <input type="hidden" id="delivery-lat" name="deliveryLat">
              <input type="hidden" id="delivery-lng" name="deliveryLng">
              <div id="delivery-info" class="mt-2" style="display: none;">
                <div class="d-flex justify-content-between align-items-center p-2 bg-light rounded">
                  <span><i class="bi bi-truck me-1"></i>Distance: <strong id="delivery-distance">-</strong> km</span>
                  <span>Fee: <strong id="delivery-fee-display" style="color: #078930;">-</strong></span>
                </div>
              </div>
            </div>

            <hr class="my-4" style="border-top: 2px dashed #dee2e6;">

            <button id="place-order-button" class="btn w-100 text-white py-3 fw-bold rounded-pill shadow"
              style="background: linear-gradient(135deg, #078930, #056b24); border: none;">
              <i class="bi bi-bag-check-fill me-2"></i>
              Place Order <span id="pay-amount">
                <%= formatPrice(cart.totalPrice) %>
              </span>
            </button>
          </form>
        </div>
      </div>
    </div>

    <!-- Order Summary -->
    <div class="col-lg-4">
      <div class="card border-0 shadow-lg" style="border-radius: 30px;">
        <div class="card-header text-white py-3 px-4"
          style="background: linear-gradient(135deg, #2c3e50, #1a252f); border-radius: 30px 30px 0 0;">
          <h5 class="mb-0"><i class="bi bi-receipt me-2"></i>
            <%= t('order_summary') %>
          </h5>
        </div>
        <div class="card-body p-4">
          <% cart.items.forEach(item=> { %>
            <div class="d-flex justify-content-between align-items-center mb-3">
              <div>
                <span class="fw-semibold">
                  <%= currentLanguage==='en' ? item.name : (item.nameAm || item.name) %>
                </span>
                <span class="text-secondary small d-block">x<%= item.qty %></span>
              </div>
              <span class="fw-bold" style="color: #078930;">
                <%= formatPrice(item.totalPrice) %>
              </span>
            </div>
            <% }) %>
              <hr>
              <div class="d-flex justify-content-between mb-2">
                <span>
                  <%= t('subtotal') %>:
                </span>
                <span class="fw-bold">
                  <%= formatPrice(cart.totalPrice) %>
                </span>
              </div>

              <!-- Promo Code -->
              <div class="promo-code-section mb-3 mt-3">
                <div class="input-group">
                  <input type="text" id="promo-code-input" class="form-control rounded-start-pill"
                    placeholder="Promo code" style="border-right: 0;">
                  <button type="button" id="apply-promo-btn" class="btn btn-outline-primary rounded-end-pill"
                    onclick="applyPromoCode()">
                    Apply
                  </button>
                </div>
                <div id="promo-feedback" class="mt-2 small"></div>
              </div>

              <!-- Discount line (hidden by default) -->
              <div id="discount-line" class="d-flex justify-content-between mb-2 text-success"
                style="display: none !important;">
                <span>Discount <span id="promo-code-display"></span></span>
                <span class="fw-bold" id="discount-amount"></span>
              </div>

              <div class="d-flex justify-content-between mb-2">
                <span>
                  <%= t('delivery_fee') %>:
                </span>
                <span class="fw-bold" id="summary-delivery-fee" style="color: #078930;">Pick location on map</span>
              </div>
              <hr>
              <div class="d-flex justify-content-between">
                <span class="h5">
                  <%= t('total') %>:
                </span>
                <span class="h5" style="color: #078930;" id="total-display">
                  <%= formatPrice(cart.totalPrice) %>
                </span>
              </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const currencySymbol = '<%= settings.currencySymbol || "ETB" %>';
  const currencyPosition = '<%= settings.currencyPosition || "left" %>';
  function fmtPrice(v) { const val = parseFloat(v).toFixed(2); return currencyPosition === 'right' ? val + ' ' + currencySymbol : currencySymbol + ' ' + val; }
  let originalTotal = <%= cart.totalPrice %>;
  let currentDiscount = 0;
  let currentDeliveryFee = 0;
  let appliedPromoCode = '';

  async function applyPromoCode() {
    const codeInput = document.getElementById('promo-code-input');
    const feedback = document.getElementById('promo-feedback');
    const code = codeInput.value.trim();

    if (!code) {
      feedback.innerHTML = '<span class="text-danger"><i class="bi bi-exclamation-circle me-1"></i>Please enter a promo code</span>';
      return;
    }

    try {
      const res = await fetch('/api/validate-promo', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ code, orderAmount: originalTotal })
      });
      const data = await res.json();

      if (data.success) {
        currentDiscount = data.discount;
        appliedPromoCode = code.toUpperCase();
        const finalAmount = originalTotal - currentDiscount;

        document.getElementById('discount-line').style.display = 'flex';
        document.getElementById('discount-line').style.cssText = '';
        document.getElementById('promo-code-display').textContent = `(${appliedPromoCode})`;
        document.getElementById('discount-amount').textContent = `-${currencySymbol} ${currentDiscount.toFixed(2)}`;

        document.getElementById('total-display').textContent = `${currencySymbol} ${finalAmount.toFixed(2)}`;
        document.getElementById('pay-amount').textContent = `${currencySymbol} ${finalAmount.toFixed(2)}`;

        feedback.innerHTML = `<span class="text-success"><i class="bi bi-check-circle-fill me-1"></i>Promo applied! You save ${currencySymbol} ${currentDiscount.toFixed(2)}</span>`;
        codeInput.disabled = true;
        document.getElementById('apply-promo-btn').disabled = true;

        if (typeof showToast === 'function') {
          showToast(`Promo code applied! You save ${currencySymbol} ${currentDiscount.toFixed(2)}`, 'success');
        }
      } else {
        feedback.innerHTML = `<span class="text-danger"><i class="bi bi-exclamation-circle me-1"></i>${data.error}</span>`;
      }
    } catch (err) {
      feedback.innerHTML = '<span class="text-danger"><i class="bi bi-exclamation-circle me-1"></i>Error validating promo code</span>';
    }
  }

  document.getElementById('place-order-button').addEventListener('click', async function (e) {
    e.preventDefault();

    const street = document.getElementById('street').value;
    const city = document.getElementById('city').value;
    const zipCode = document.getElementById('zipCode').value;

    if (!street || !city || !zipCode) {
      if (typeof showToast === 'function') {
        showToast('Please fill in all shipping address fields', 'error');
      } else {
        alert('Please fill in all shipping address fields.');
      }
      return;
    }

    const cartDataElement = document.getElementById('cart-data');
    const cartItems = JSON.parse(cartDataElement.dataset.cart);
    const deliveryLat = document.getElementById('delivery-lat').value;
    const deliveryLng = document.getElementById('delivery-lng').value;

    const button = this;
    button.disabled = true;
    button.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Placing order...';

    try {
      const response = await fetch('/api/place-order', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          paymentMethod: 'cash',
          amount: originalTotal,
          cart: cartItems,
          shippingAddress: { street, city, zipCode },
          deliveryLocation: deliveryLat && deliveryLng ? { lat: parseFloat(deliveryLat), lng: parseFloat(deliveryLng) } : {},
          promoCode: appliedPromoCode
        })
      });

      const data = await response.json();

      if (data.success) {
        if (typeof showToast === 'function') {
          showToast('Order placed successfully!', 'success');
        }
        window.location.href = `/order-confirmation/${data.orderId}`;
      } else {
        if (typeof showToast === 'function') {
          showToast('Order failed: ' + (data.error || 'Unknown error'), 'error');
        } else {
          alert('Order failed: ' + (data.error || 'Unknown error'));
        }
        button.disabled = false;
        button.innerHTML = `<i class="bi bi-bag-check-fill me-2"></i>Place Order <span id="pay-amount">${fmtPrice(originalTotal - currentDiscount + currentDeliveryFee)}</span>`;
      }
    } catch (err) {
      console.error('Order error:', err);
      if (typeof showToast === 'function') {
        showToast('Network error. Please try again.', 'error');
      } else {
        alert('Network error. Please try again.');
      }
      button.disabled = false;
      button.innerHTML = `<i class="bi bi-bag-check-fill me-2"></i>Place Order <span id="pay-amount">${fmtPrice(originalTotal - currentDiscount + currentDeliveryFee)}</span>`;
    }
  });

  // Leaflet Map Initialization
  const restaurantLat = <%= settings.restaurantLat ? settings.restaurantLat : 9.0192 %>;
  const restaurantLng = <%= settings.restaurantLng ? settings.restaurantLng : 38.7525 %>;

  const map = L.map('delivery-map').setView([restaurantLat, restaurantLng], 13);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; OpenStreetMap contributors',
    maxZoom: 19
  }).addTo(map);

  // Restaurant marker
  L.marker([restaurantLat, restaurantLng], {
    icon: L.divIcon({ className: 'restaurant-marker', html: '<div style="background:#078930;color:white;border-radius:50%;width:30px;height:30px;display:flex;align-items:center;justify-content:center;font-size:14px;box-shadow:0 2px 8px rgba(0,0,0,0.3);"><i class="bi bi-shop"></i></div>' })
  }).addTo(map).bindPopup('Restaurant Location');

  let deliveryMarker = null;

  map.on('click', async function (e) {
    const { lat, lng } = e.latlng;

    if (deliveryMarker) map.removeLayer(deliveryMarker);
    deliveryMarker = L.marker([lat, lng], {
      icon: L.divIcon({ className: 'delivery-marker', html: '<div style="background:#e74c3c;color:white;border-radius:50%;width:30px;height:30px;display:flex;align-items:center;justify-content:center;font-size:14px;box-shadow:0 2px 8px rgba(0,0,0,0.3);"><i class="bi bi-geo-alt-fill"></i></div>' })
    }).addTo(map).bindPopup('Delivery Location').openPopup();

    document.getElementById('delivery-lat').value = lat;
    document.getElementById('delivery-lng').value = lng;

    // Calculate delivery fee
    try {
      const resp = await fetch('/api/calculate-delivery', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ lat, lng })
      });
      const data = await resp.json();
      if (data.success) {
        currentDeliveryFee = data.deliveryFee;
        document.getElementById('delivery-distance').textContent = data.distance;
        document.getElementById('delivery-fee-display').textContent = fmtPrice(data.deliveryFee);
        document.getElementById('delivery-info').style.display = 'block';
        document.getElementById('summary-delivery-fee').textContent = fmtPrice(data.deliveryFee);
        updateTotals();
      }
    } catch (err) {
      console.error('Delivery calculation error:', err);
    }
  });

  function updateTotals() {
    const finalTotal = originalTotal - currentDiscount + currentDeliveryFee;
    document.getElementById('total-display').textContent = fmtPrice(finalTotal);
    document.getElementById('pay-amount').textContent = fmtPrice(finalTotal);
  }

  // Fix map rendering after card becomes visible
  setTimeout(() => { map.invalidateSize(); }, 300);
</script>