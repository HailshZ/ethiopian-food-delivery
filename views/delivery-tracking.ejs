<div class="container py-5">
    <a href="/orders" class="btn btn-outline-secondary rounded-pill mb-4"><i class="bi bi-arrow-left me-1"></i> Back to
        Orders</a>

    <div class="row g-4">
        <!-- Map -->
        <div class="col-lg-8">
            <div class="glass-card p-0 overflow-hidden" style="border-radius: 20px;">
                <div id="delivery-map" style="height: 400px; width: 100%; background: #e8e8e8;">
                    <div class="d-flex align-items-center justify-content-center h-100 text-muted" id="map-placeholder">
                        <div class="text-center">
                            <i class="bi bi-geo-alt-fill" style="font-size: 3rem;"></i>
                            <p>Loading map...</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Order Items -->
            <div class="glass-card mt-4">
                <h5 class="mb-3"><i class="bi bi-bag me-2"></i>Order Items</h5>
                <% order.items.forEach(item=> { %>
                    <div class="d-flex align-items-center py-2 border-bottom">
                        <img src="<%= item.imageUrl %>" class="rounded-3 me-3"
                            style="width:50px;height:50px;object-fit:cover;"
                            onerror="this.src='https://images.unsplash.com/photo-1604329760661-e71dc83f8f26?w=100'">
                        <div class="flex-grow-1">
                            <strong>
                                <%= item.name %>
                            </strong>
                            <span class="text-muted ms-2">x<%= item.qty %></span>
                        </div>
                        <span class="fw-bold text-primary">$<%= item.totalPrice.toFixed(2) %></span>
                    </div>
                    <% }) %>
                        <div class="d-flex justify-content-between mt-3 pt-2">
                            <span class="h5">Total</span>
                            <span class="h5 text-primary">$<%= order.totalAmount.toFixed(2) %></span>
                        </div>
            </div>
        </div>

        <!-- Timeline -->
        <div class="col-lg-4">
            <div class="glass-card sticky-top" style="top: 100px;">
                <h5 class="mb-3"><i class="bi bi-clock-history me-2"></i>Delivery Status</h5>

                <div class="status-badge-container mb-3">
                    <span
                        class="badge bg-<%= order.orderStatus === 'delivered' ? 'success' : order.orderStatus === 'cancelled' ? 'danger' : 'warning' %> rounded-pill px-3 py-2"
                        id="order-status-badge">
                        <%= order.orderStatus.charAt(0).toUpperCase() + order.orderStatus.slice(1) %>
                    </span>
                    <% if (order.estimatedDelivery) { %>
                        <div class="mt-2 text-muted small">
                            <i class="bi bi-clock me-1"></i>ETA: <%= new
                                Date(order.estimatedDelivery).toLocaleTimeString() %>
                        </div>
                        <% } %>
                </div>

                <div class="delivery-timeline" id="delivery-timeline">
                    <% if (order.deliveryUpdates && order.deliveryUpdates.length> 0) { %>
                        <% order.deliveryUpdates.forEach((update, i)=> { %>
                            <div class="timeline-item <%= i === order.deliveryUpdates.length - 1 ? 'active' : '' %>">
                                <div class="timeline-dot"></div>
                                <div class="timeline-content">
                                    <strong>
                                        <%= update.status %>
                                    </strong>
                                    <p class="mb-0 small text-muted">
                                        <%= update.note || '' %>
                                    </p>
                                    <span class="small text-muted">
                                        <%= new Date(update.timestamp).toLocaleString() %>
                                    </span>
                                </div>
                            </div>
                            <% }) %>
                                <% } %>
                </div>

                <div class="mt-3">
                    <h6>Delivery Address</h6>
                    <p class="text-muted mb-0">
                        <i class="bi bi-geo-alt me-1"></i>
                        <%= order.shippingAddress.street %>, <%= order.shippingAddress.city %>
                                <%= order.shippingAddress.zipCode %>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<% if (googleMapsApiKey) { %>
    <script src="https://maps.googleapis.com/maps/api/js?key=<%= googleMapsApiKey %>&callback=initDeliveryMap" async
        defer></script>
    <% } %>
        <script>
            const orderId = '<%= order._id %>';
            let map, marker;

            function initDeliveryMap() {
                const lat = <%= order.deliveryLocation ?order.deliveryLocation.lat: 9.0192 %>;
                const lng = <%= order.deliveryLocation ?order.deliveryLocation.lng: 38.7525 %>;
                const pos = { lat, lng };

                map = new google.maps.Map(document.getElementById('delivery-map'), {
                    zoom: 15,
                    center: pos,
                    styles: [
                        { featureType: 'poi', stylers: [{ visibility: 'off' }] },
                        { featureType: 'transit', stylers: [{ visibility: 'off' }] }
                    ]
                });

                marker = new google.maps.Marker({
                    position: pos,
                    map: map,
                    title: 'Delivery Location',
                    icon: {
                        url: 'data:image/svg+xml,' + encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24"><path fill="%23078930" d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>'),
                        scaledSize: new google.maps.Size(40, 40)
                    }
                });

                document.getElementById('map-placeholder')?.remove();
            }

            // Poll for delivery updates every 15 seconds
            if (orderId) {
                setInterval(async () => {
                    try {
                        const res = await fetch(`/api/delivery/${orderId}`);
                        const data = await res.json();
                        if (data.success) {
                            // Update status badge
                            const badge = document.getElementById('order-status-badge');
                            if (badge) badge.textContent = data.status.charAt(0).toUpperCase() + data.status.slice(1);

                            // Update marker if map loaded
                            if (marker && data.location) {
                                marker.setPosition({ lat: data.location.lat, lng: data.location.lng });
                                map.panTo({ lat: data.location.lat, lng: data.location.lng });
                            }
                        }
                    } catch (e) { /* silent */ }
                }, 15000);
            }

            // Fallback if no Google Maps API key
            if (!('<%= googleMapsApiKey %>')) {
                document.getElementById('map-placeholder').innerHTML =
                    '<div class="text-center"><i class="bi bi-geo-alt-fill" style="font-size:3rem;color:#078930;"></i><p class="mt-2">Map requires Google Maps API key</p><p class="small text-muted">Add GOOGLE_MAPS_API_KEY to your .env file</p></div>';
            }
        </script>