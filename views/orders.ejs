<div class="container py-5">
  <h1 class="section-title text-center mb-5"><i class="bi bi-bag-check me-2"></i>
    <%= t('my_orders') %>
  </h1>

  <% if (orders.length===0) { %>
    <div class="empty-state">
      <i class="bi bi-bag-x"></i>
      <h4>
        <%= t('no_orders_yet') %>
      </h4>
      <a href="/menu" class="btn btn-primary rounded-pill px-5 mt-3"><i class="bi bi-cart me-2"></i>
        <%= t('order_now') %>
      </a>
    </div>
    <% } else { %>
      <div class="row g-4">
        <% orders.forEach(order=> { %>
          <div class="col-md-6 col-lg-4">
            <div class="glass-card h-100 order-card">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="fw-bold text-muted">#<%= order._id.toString().slice(-8) %></span>
                <span
                  class="badge rounded-pill px-3 py-2 bg-<%= order.orderStatus === 'delivered' ? 'success' : order.orderStatus === 'cancelled' ? 'danger' : order.orderStatus === 'confirmed' ? 'primary' : 'warning' %>">
                  <%= order.orderStatus %>
                </span>
              </div>
              <div class="mb-3">
                <div class="d-flex justify-content-between mb-1">
                  <span class="text-muted"><i class="bi bi-calendar3 me-1"></i>Date</span>
                  <span>
                    <%= new Date(order.createdAt).toLocaleDateString() %>
                  </span>
                </div>
                <div class="d-flex justify-content-between mb-1">
                  <span class="text-muted"><i class="bi bi-credit-card me-1"></i>Payment</span>
                  <span class="badge bg-<%= order.paymentStatus === 'paid' ? 'success' : 'warning' %>">
                    <%= order.paymentStatus %>
                  </span>
                </div>
                <div class="d-flex justify-content-between">
                  <span class="text-muted"><i class="bi bi-bag me-1"></i>Items</span>
                  <span>
                    <%= order.items.length %> items
                  </span>
                </div>
              </div>
              <div class="d-flex justify-content-between align-items-center pt-2 border-top">
                <span class="h5 mb-0 text-primary">$<%= order.totalAmount.toFixed(2) %></span>
                <a href="/delivery/<%= order._id %>" class="btn btn-sm btn-primary rounded-pill">
                  <i class="bi bi-geo-alt me-1"></i>Track
                </a>
              </div>
            </div>
          </div>
          <% }) %>
      </div>
      <% } %>
</div>