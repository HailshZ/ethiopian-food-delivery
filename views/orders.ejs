<div class="container py-5">
  <div class="section-header text-center mb-4">
    <h2 class="section-title"><i class="bi bi-bag-check me-2"></i>
      <%= t('my_orders') %>
    </h2>
    <div class="section-divider"></div>
  </div>

  <% if (!orders || orders.length===0) { %>
    <div class="empty-state">
      <i class="bi bi-bag-x"></i>
      <h4>
        <%= t('no_orders_yet') %>
      </h4>
      <a href="/menu" class="btn btn-primary rounded-pill mt-3"><i class="bi bi-bag me-1"></i>
        <%= t('order_now') || 'Start Ordering' %>
      </a>
    </div>
    <% } else { %>
      <div class="row g-4">
        <% orders.forEach(order=> { %>
          <div class="col-md-6 col-lg-4" style="animation: fadeInUp 0.4s ease;">
            <div class="glass-card order-card h-100">
              <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                  <h6 class="fw-bold mb-1">Order #<%= order._id.toString().slice(-8) %>
                  </h6>
                  <span class="text-muted small">
                    <%= new Date(order.createdAt).toLocaleDateString() %>
                  </span>
                </div>
                <span
                  class="badge bg-<%= order.orderStatus === 'delivered' ? 'success' : order.orderStatus === 'cancelled' ? 'danger' : order.orderStatus === 'confirmed' ? 'info' : order.orderStatus === 'preparing' ? 'warning' : 'secondary' %> rounded-pill px-3 py-2">
                  <%= order.orderStatus.charAt(0).toUpperCase() + order.orderStatus.slice(1) %>
                </span>
              </div>

              <div class="mb-3">
                <% order.items.slice(0, 3).forEach(item=> { %>
                  <div class="d-flex align-items-center gap-2 mb-2">
                    <img src="<%= item.imageUrl %>" class="rounded-2"
                      style="width: 36px; height: 36px; object-fit: cover;"
                      onerror="this.src='https://images.unsplash.com/photo-1604329760661-e71dc83f8f26?w=100'">
                    <span class="small">
                      <%= item.name %> x<%= item.qty %>
                    </span>
                  </div>
                  <% }) %>
                    <% if (order.items.length> 3) { %>
                      <span class="text-muted small">+<%= order.items.length - 3 %> more items</span>
                      <% } %>
              </div>

              <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                  <span class="fw-bold text-primary">
                    <%= settings.currencySymbol || 'ETB' %>
                      <%= (order.finalAmount || order.totalAmount).toFixed(2) %>
                  </span>
                  <% if (order.discount> 0) { %>
                    <span class="text-success small ms-1">(-<%= settings.currencySymbol || 'ETB' %>
                        <%= order.discount.toFixed(2) %>)</span>
                    <% } %>
                </div>
                <span class="badge bg-<%= order.paymentStatus === 'paid' ? 'success' : 'warning' %> rounded-pill">
                  <%= order.paymentStatus %>
                </span>
              </div>

              <div class="d-flex gap-2">
                <a href="/delivery/<%= order._id %>" class="btn btn-outline-primary btn-sm rounded-pill flex-fill">
                  <i class="bi bi-geo-alt me-1"></i> Track
                </a>
                <% if (order.orderStatus==='delivered' && !order.isReviewed) { %>
                  <a href="/review/<%= order._id %>" class="btn btn-warning btn-sm rounded-pill flex-fill">
                    <i class="bi bi-star me-1"></i> Review
                  </a>
                  <% } else if (order.isReviewed) { %>
                    <span class="btn btn-outline-success btn-sm rounded-pill flex-fill disabled">
                      <i class="bi bi-check-circle me-1"></i> Reviewed
                    </span>
                    <% } %>
              </div>
            </div>
          </div>
          <% }) %>
      </div>
      <% } %>
</div>