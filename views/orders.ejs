<div class="container py-5">
  <h1 class="fw-bold mb-5 text-center" style="color: #078930;"><%= t('my_orders') %></h1>

  <% if (orders.length === 0) { %>
    <div class="text-center py-5">
      <i class="bi bi-box" style="font-size: 4rem; color: #95a5a6;"></i>
      <h4 class="mt-3 text-secondary"><%= t('no_orders_yet') %></h4>
      <a href="/menu" class="btn btn-primary mt-4 px-5 py-3" style="background: linear-gradient(135deg, #078930, #056b24); border: none; border-radius: 50px;">
        <i class="bi bi-cart me-2"></i><%= t('order_now') %>
      </a>
    </div>
  <% } else { %>
    <div class="row g-4">
      <% orders.forEach(order => { %>
        <div class="col-md-6 col-lg-4">
          <div class="card border-0 shadow-sm h-100" style="border-radius: 20px; transition: all 0.3s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='none'">
            <div class="card-header d-flex justify-content-between align-items-center bg-white py-3 px-4" style="border-bottom: 2px solid #fcdd09;">
              <span class="fw-semibold">#<%= order._id.toString().slice(-8) %></span>
              <span class="badge rounded-pill px-3 py-2" style="background: <%= order.orderStatus === 'delivered' ? '#27ae60' : (order.orderStatus === 'cancelled' ? '#da121a' : '#f39c12') %>;">
                <%= order.orderStatus %>
              </span>
            </div>
            <div class="card-body p-4">
              <p class="mb-2"><i class="bi bi-calendar3 me-2" style="color: #078930;"></i><%= new Date(order.createdAt).toLocaleDateString() %></p>
              <p class="mb-2"><i class="bi bi-credit-card me-2" style="color: #078930;"></i>Payment: <%= order.paymentStatus %></p>
              <p class="fw-bold fs-5 mb-3" style="color: #078930;">Total: $<%= order.totalAmount.toFixed(2) %></p>
              <a href="/order-confirmation/<%= order._id %>" class="btn btn-outline-primary w-100" style="border: 2px solid #078930; color: #078930; border-radius: 50px;">
                <i class="bi bi-eye me-2"></i><%= t('view_details') %>
              </a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>