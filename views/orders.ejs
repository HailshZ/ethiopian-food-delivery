<div class="container py-4">
  <h1 class="mb-4" style="color: #078930;"><i class="bi bi-bag-check me-2"></i>My Orders</h1>

  <% if (orders.length === 0) { %>
    <div class="alert alert-info text-center py-5">
      <i class="bi bi-box" style="font-size: 3rem;"></i>
      <h4 class="mt-3">No orders yet</h4>
      <p>Start by ordering some delicious Ethiopian dishes!</p>
      <a href="/menu" class="btn btn-primary mt-3">Browse Menu</a>
    </div>
  <% } else { %>
    <div class="row g-4">
      <% orders.forEach(order => { %>
        <div class="col-md-6">
          <div class="card shadow-sm">
            <div class="card-header bg-light d-flex justify-content-between">
              <span>Order #<%= order._id.toString().slice(-8) %></span>
              <span class="badge bg-<%= order.orderStatus === 'delivered' ? 'success' : (order.orderStatus === 'cancelled' ? 'danger' : 'warning') %>">
                <%= order.orderStatus %>
              </span>
            </div>
            <div class="card-body">
              <p><i class="bi bi-calendar me-2"></i><%= new Date(order.createdAt).toLocaleDateString() %></p>
              <p><i class="bi bi-credit-card me-2"></i>Payment: <%= order.paymentStatus %></p>
              <p class="fw-bold">Total: $<%= order.totalAmount.toFixed(2) %></p>
              <a href="/order/<%= order._id %>" class="btn btn-outline-primary btn-sm">View Details</a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>