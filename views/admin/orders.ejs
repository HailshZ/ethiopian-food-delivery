<div class="container py-4">
    <h1 class="mb-4" style="color: #078930;"><i class="bi bi-truck me-2"></i>Manage Orders</h1>

    <!-- Filter buttons -->
    <div class="mb-4">
        <div class="btn-group" role="group">
            <a href="/admin/orders" class="btn btn-<%= currentStatus === 'all' ? 'primary' : 'outline-primary' %> rounded-pill">All</a>
            <a href="/admin/orders?status=pending" class="btn btn-<%= currentStatus === 'pending' ? 'warning' : 'outline-warning' %> rounded-pill">Pending</a>
            <a href="/admin/orders?status=confirmed" class="btn btn-<%= currentStatus === 'confirmed' ? 'info' : 'outline-info' %> rounded-pill">Confirmed</a>
            <a href="/admin/orders?status=preparing" class="btn btn-<%= currentStatus === 'preparing' ? 'secondary' : 'outline-secondary' %> rounded-pill">Preparing</a>
            <a href="/admin/orders?status=delivered" class="btn btn-<%= currentStatus === 'delivered' ? 'success' : 'outline-success' %> rounded-pill">Delivered</a>
            <a href="/admin/orders?status=cancelled" class="btn btn-<%= currentStatus === 'cancelled' ? 'danger' : 'outline-danger' %> rounded-pill">Cancelled</a>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <% if (orders.length === 0) { %>
                <p class="text-muted">No orders found.</p>
            <% } else { %>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Customer</th>
                                <th>Items</th>
                                <th>Total</th>
                                <th>Status</th>
                                <th>Payment</th>
                                <th>Date</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% orders.forEach(order => { %>
                                <tr>
                                    <td>#<%= order._id.toString().slice(-6) %></td>
                                    <td>
                                        <strong><%= order.user ? order.user.name : 'N/A' %></strong><br>
                                        <small><%= order.user ? order.user.email : '' %></small>
                                    </td>
                                    <td>
                                        <ul class="list-unstyled mb-0">
                                            <% order.items.slice(0,2).forEach(item => { %>
                                                <li><%= item.qty %>x <%= item.name %></li>
                                            <% }) %>
                                            <% if (order.items.length > 2) { %>
                                                <li>... and <%= order.items.length - 2 %> more</li>
                                            <% } %>
                                        </ul>
                                    </td>
                                    <td class="fw-bold">$<%= order.totalAmount.toFixed(2) %></td>
                                    <td>
                                        <span class="badge bg-<%= order.orderStatus === 'delivered' ? 'success' : (order.orderStatus === 'cancelled' ? 'danger' : 'warning') %>">
                                            <%= order.orderStatus %>
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge bg-<%= order.paymentStatus === 'paid' ? 'success' : 'secondary' %>">
                                            <%= order.paymentStatus %>
                                        </span>
                                    </td>
                                    <td><%= new Date(order.createdAt).toLocaleDateString() %></td>
                                    <td>
                                        <form action="/admin/order/<%= order._id %>/update" method="post" class="d-flex">
                                            <select name="status" class="form-select form-select-sm me-2">
                                                <option value="pending" <%= order.orderStatus === 'pending' ? 'selected' : '' %>>Pending</option>
                                                <option value="confirmed" <%= order.orderStatus === 'confirmed' ? 'selected' : '' %>>Confirmed</option>
                                                <option value="preparing" <%= order.orderStatus === 'preparing' ? 'selected' : '' %>>Preparing</option>
                                                <option value="delivered" <%= order.orderStatus === 'delivered' ? 'selected' : '' %>>Delivered</option>
                                                <option value="cancelled" <%= order.orderStatus === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                                            </select>
                                            <button type="submit" class="btn btn-sm btn-outline-primary">Update</button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>
    </div>
</div>