<div class="container py-4">
    <h1 class="mb-4" style="color: #078930;"><i class="bi bi-check2-square me-2"></i>Pending Approvals</h1>

    <!-- Pending Dishes -->
    <div class="card shadow-sm border-0 mb-4" style="border-radius: 15px;">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-egg-fried me-2"></i>Dishes (<%= pendingDishes.length %>)</h5>
        </div>
        <div class="card-body">
            <% if (pendingDishes.length===0) { %>
                <p class="text-muted">No pending dishes.</p>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Dish</th>
                                    <th>Owner</th>
                                    <th>Category</th>
                                    <th>Price</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% pendingDishes.forEach(d=> { %>
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <img src="<%= d.imageUrl %>" class="rounded-2"
                                                    style="width:40px;height:40px;object-fit:cover;"
                                                    onerror="this.src='https://images.unsplash.com/photo-1604329760661-e71dc83f8f26?w=100'">
                                                <div>
                                                    <strong>
                                                        <%= d.name %>
                                                    </strong>
                                                    <small class="d-block text-muted">
                                                        <%= d.nameAm %>
                                                    </small>
                                                    <small class="text-muted">
                                                        <%= d.description.substring(0, 60) %>...
                                                    </small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <% if (d.owner) { %>
                                                <span class="badge bg-info rounded-pill">
                                                    <%= d.owner.restaurantName || d.owner.name %>
                                                </span>
                                                <% } else { %>
                                                    <span class="text-muted">N/A</span>
                                                    <% } %>
                                        </td>
                                        <td><span class="badge bg-secondary">
                                                <%= d.category %>
                                            </span></td>
                                        <td class="fw-bold">
                                            <%= formatPrice(d.price) %>
                                        </td>
                                        <td>
                                            <form action="/admin/dish/<%= d.id %>/approve" method="post"
                                                class="d-inline">
                                                <button class="btn btn-sm btn-success rounded-pill me-1"><i
                                                        class="bi bi-check-lg me-1"></i>Approve</button>
                                            </form>
                                            <form action="/admin/dish/<%= d.id %>/reject" method="post"
                                                class="d-inline">
                                                <button class="btn btn-sm btn-danger rounded-pill"><i
                                                        class="bi bi-x-lg me-1"></i>Reject</button>
                                            </form>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <% } %>
        </div>
    </div>

    <!-- Pending Meal Plans -->
    <div class="card shadow-sm border-0" style="border-radius: 15px;">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-calendar-week me-2"></i>Meal Plans (<%= pendingPlans.length %>)</h5>
        </div>
        <div class="card-body">
            <% if (pendingPlans.length===0) { %>
                <p class="text-muted">No pending meal plans.</p>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Plan</th>
                                    <th>Owner</th>
                                    <th>Price</th>
                                    <th>Duration</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% pendingPlans.forEach(p=> { %>
                                    <tr>
                                        <td><strong>
                                                <%= p.name %>
                                            </strong><br><small class="text-muted">
                                                <%= p.description ? p.description.substring(0, 60) : '' %>...
                                            </small></td>
                                        <td>
                                            <% if (p.owner) { %>
                                                <span class="badge bg-info rounded-pill">
                                                    <%= p.owner.restaurantName || p.owner.name %>
                                                </span>
                                                <% } else { %>
                                                    <span class="text-muted">N/A</span>
                                                    <% } %>
                                        </td>
                                        <td class="fw-bold">
                                            <%= formatPrice(p.price) %>
                                        </td>
                                        <td>
                                            <%= p.duration %>
                                        </td>
                                        <td>
                                            <form action="/admin/mealplan/<%= p.id %>/approve" method="post"
                                                class="d-inline">
                                                <button class="btn btn-sm btn-success rounded-pill me-1"><i
                                                        class="bi bi-check-lg me-1"></i>Approve</button>
                                            </form>
                                            <form action="/admin/mealplan/<%= p.id %>/reject" method="post"
                                                class="d-inline">
                                                <button class="btn btn-sm btn-danger rounded-pill"><i
                                                        class="bi bi-x-lg me-1"></i>Reject</button>
                                            </form>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <% } %>
        </div>
    </div>
</div>