<div class="container py-4">
    <h1 class="mb-4" style="color: #078930;"><i class="bi bi-shop me-2"></i>Providers</h1>

    <!-- Add Owner -->
    <div class="card shadow-sm border-0 mb-4" style="border-radius: 15px;">
        <div class="card-header bg-white">
            <h5 class="mb-0"><i class="bi bi-person-plus me-2"></i>Add New Provider</h5>
        </div>
        <div class="card-body">
            <form action="/admin/owner/add" method="post">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label for="name" class="form-label">Full Name</label>
                        <input type="text" name="name" id="name" class="form-control" placeholder="Full Name" required>
                    </div>
                    <div class="col-md-3">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" name="email" id="email" class="form-control" placeholder="Email">
                    </div>
                    <div class="col-md-3">
                        <label for="phone" class="form-label">Phone Number</label>
                        <input type="tel" name="phone" id="phone" class="form-control" placeholder="+251987654321" required>
                    </div>
                    <div class="col-md-2">
                        <label for="password" class="form-label">Password</label>
                        <input type="password" name="password" id="password" class="form-control" placeholder="Password" required minlength="6">
                    </div>
                    <div class="col-md-2">
                        <label for="restaurantName" class="form-label">Restaurant Name</label>
                        <input type="text" name="restaurantName" id="restaurantName" class="form-control" placeholder="Restaurant Name">
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-success w-100 rounded-pill mt-4"><i class="bi bi-plus me-1"></i>Add Provider</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Owners List -->
    <div class="card shadow-sm border-0" style="border-radius: 15px;">
        <div class="card-body">
            <% if (owners.length===0) { %>
                <p class="text-muted">No providers yet.</p>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Restaurant</th>
                                    <th>Status</th>
                                    <th>Joined</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% owners.forEach(o=> { %>
                                     <tr>
                                        <td><strong><%= o.name %></strong></td>
                                        <td><%= o.email %></td>
                                        <td><span class="badge bg-info rounded-pill"><%= o.restaurantName || 'N/A' %></span></td>
                                        <td><span class="badge bg-<%= o.isActive ? 'success' : 'danger' %> rounded-pill"><%= o.isActive ? 'Active' : 'Inactive' %></span></td>
                                        <td><%= new Date(o.createdAt).toLocaleDateString() %></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
        </div>
    </div>
</div>