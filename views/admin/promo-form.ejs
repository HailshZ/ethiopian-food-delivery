<div class="container py-5">
    <a href="/admin/promos" class="btn btn-outline-secondary rounded-pill mb-4"><i class="bi bi-arrow-left me-1"></i>
        Back to Promos</a>

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="glass-card">
                <h3 class="fw-bold mb-4"><i class="bi bi-tag-fill me-2 text-primary"></i>Create Promo Code</h3>

                <form action="/admin/promo/add" method="POST">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Promo Code</label>
                        <input type="text" name="code" class="form-control rounded-3 text-uppercase"
                            placeholder="e.g. WELCOME20" required style="letter-spacing: 2px; font-weight: 600;">
                        <div class="form-text">Code will be automatically uppercased</div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Discount Type</label>
                            <select name="discountType" class="form-select rounded-3" id="discountType">
                                <option value="percentage">Percentage (%)</option>
                                <option value="fixed">Fixed Amount</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Discount Value</label>
                            <input type="number" step="0.01" name="discountValue" class="form-control rounded-3"
                                placeholder="e.g. 20" required min="0">
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Min Order Amount (<%= settings.currencySymbol || 'ETB'
                                    %>)</label>
                            <input type="number" step="0.01" name="minOrderAmount" class="form-control rounded-3"
                                placeholder="0" value="0" min="0">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Max Uses (0 = unlimited)</label>
                            <input type="number" name="maxUses" class="form-control rounded-3" placeholder="0" value="0"
                                min="0">
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Expiry Date (optional)</label>
                        <input type="date" name="expiresAt" class="form-control rounded-3">
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg rounded-pill w-100">
                        <i class="bi bi-plus-lg me-2"></i>Create Promo Code
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>