<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 style="color: #078930;"><i class="bi bi-calendar-week me-2"></i>Meal Plans</h1>
        <a href="/admin/meal-plan/add" class="btn btn-success rounded-pill"><i class="bi bi-plus-circle me-1"></i>Add
            Meal Plan</a>
    </div>

    <div class="card shadow-sm border-0" style="border-radius: 15px;">
        <div class="card-body">
            <% if (plans.length===0) { %>
                <p class="text-muted">No meal plans yet.</p>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Owner</th>
                                    <th>Price</th>
                                    <th>Duration</th>
                                    <th>Status</th>
                                    <th>Approval</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% plans.forEach(p=> { %>
                                    <tr>
                                        <td><strong>
                                                <%= p.name %>
                                            </strong><br><small class="text-muted">
                                                <%= p.nameAm %>
                                            </small></td>
                                        <td>
                                            <% if (p.owner) { %>
                                                <span class="badge bg-info rounded-pill">
                                                    <%= p.owner.restaurantName || p.owner.name %>
                                                </span>
                                                <% } else { %>
                                                    <span class="text-muted">Admin</span>
                                                    <% } %>
                                        </td>
                                        <td class="fw-bold">
                                            <%= formatPrice(p.price) %>
                                        </td>
                                        <td>
                                            <%= p.duration %>
                                        </td>
                                        <td>
                                            <span
                                                class="badge bg-<%= p.isActive ? 'success' : 'secondary' %> rounded-pill">
                                                <%= p.isActive ? 'Active' : 'Inactive' %>
                                            </span>
                                        </td>
                                        <td>
                                            <span
                                                class="badge bg-<%= p.approvalStatus === 'approved' ? 'success' : p.approvalStatus === 'pending' ? 'warning' : 'danger' %> rounded-pill">
                                                <%= p.approvalStatus %>
                                            </span>
                                        </td>
                                        <td>
                                            <form action="/admin/meal-plan/<%= p.id %>/toggle" method="post"
                                                class="d-inline">
                                                <button
                                                    class="btn btn-sm btn-outline-<%= p.isActive ? 'warning' : 'success' %> rounded-pill">
                                                    <%= p.isActive ? 'Deactivate' : 'Activate' %>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <% } %>
        </div>
    </div>
</div>