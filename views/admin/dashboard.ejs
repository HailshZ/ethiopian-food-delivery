<div class="container py-4">
  <h1 class="mb-4" style="color: #078930;"><i class="bi bi-speedometer2 me-2"></i>Admin Dashboard</h1>

  <div class="row g-4 mb-4">
    <div class="col-md-3">
      <div class="card text-white bg-primary shadow-sm">
        <div class="card-body">
          <h5 class="card-title">Total Orders</h5>
          <p class="display-4">
            <%= totalOrders %>
          </p>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card text-white bg-success shadow-sm">
        <div class="card-body">
          <h5 class="card-title">Revenue</h5>
          <p class="display-4">
            <%= settings.currencySymbol || 'ETB' %>
              <%= totalRevenue.toFixed(2) %>
          </p>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card text-white bg-warning shadow-sm">
        <div class="card-body">
          <h5 class="card-title">Menu Items</h5>
          <p class="display-4">
            <%= totalDishes %>
          </p>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card text-white bg-info shadow-sm">
        <div class="card-body">
          <h5 class="card-title">Users</h5>
          <p class="display-4">
            <%= totalUsers %>
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-md-8">
      <div class="card shadow-sm">
        <div class="card-header bg-secondary text-white">
          <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Recent Orders</h5>
        </div>
        <div class="card-body">
          <% if (recentOrders.length===0) { %>
            <p class="text-muted">No orders yet.</p>
            <% } else { %>
              <div class="table-responsive">
                <table class="table table-hover">
                  <thead>
                    <tr>
                      <th>Order ID</th>
                      <th>Customer</th>
                      <th>Total</th>
                      <th>Status</th>
                      <th>Date</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% recentOrders.forEach(order=> { %>
                      <tr>
                        <td>#<%= order._id.toString().slice(-6) %>
                        </td>
                        <td>
                          <%= order.user ? order.user.name : 'N/A' %>
                        </td>
                        <td>
                          <%= settings.currencySymbol || 'ETB' %>
                            <%= order.totalAmount.toFixed(2) %>
                        </td>
                        <td>
                          <span
                            class="badge bg-<%= order.orderStatus === 'delivered' ? 'success' : (order.orderStatus === 'cancelled' ? 'danger' : 'warning') %>">
                            <%= order.orderStatus %>
                          </span>
                        </td>
                        <td>
                          <%= new Date(order.createdAt).toLocaleDateString() %>
                        </td>
                      </tr>
                      <% }) %>
                  </tbody>
                </table>
              </div>
              <% } %>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card shadow-sm">
        <div class="card-header bg-secondary text-white">
          <h5 class="mb-0"><i class="bi bi-gear me-2"></i>Quick Actions</h5>
        </div>
        <div class="card-body">
          <a href="/admin/orders" class="btn btn-outline-primary w-100 mb-2">
            <i class="bi bi-list-check me-2"></i>Manage Orders
          </a>
          <a href="/admin/menu" class="btn btn-outline-success w-100 mb-2">
            <i class="bi bi-menu-button-wide me-2"></i>Manage Menu
          </a>
          <a href="/admin/dish/add" class="btn btn-outline-warning w-100 mb-2">
            <i class="bi bi-plus-circle me-2"></i>Add New Dish
          </a>
          <a href="/admin/promos" class="btn btn-outline-info w-100 mb-2">
            <i class="bi bi-tags me-2"></i>Promo Codes (<%= totalPromos %>)
          </a>
          <% if (session.role==='superadmin' ) { %>
            <a href="/superadmin/settings" class="btn btn-outline-danger w-100 mb-2">
              <i class="bi bi-shield-lock me-2"></i>System Settings
            </a>
            <% } %>
        </div>
      </div>
    </div>
  </div>
</div>