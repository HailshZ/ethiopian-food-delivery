<div class="container-fluid py-4 px-4">
    <!-- Admin Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-speedometer2 me-2"></i>Admin Dashboard</h2>
            <p class="text-muted mb-0">Welcome back, <%= session.userName %>
            </p>
        </div>
        <div>
            <a href="/admin/seed" class="btn btn-outline-warning rounded-pill me-2"><i
                    class="bi bi-database me-1"></i>Seed Data</a>
            <a href="/" class="btn btn-outline-secondary rounded-pill"><i class="bi bi-house me-1"></i>View Site</a>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-6 col-lg-3">
            <div class="admin-stat-card" style="--accent: var(--primary);">
                <div class="admin-stat-icon"><i class="bi bi-bag-check"></i></div>
                <div>
                    <div class="admin-stat-value">
                        <%= stats.totalOrders %>
                    </div>
                    <div class="admin-stat-label">Total Orders</div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="admin-stat-card" style="--accent: var(--ethio-yellow);">
                <div class="admin-stat-icon"><i class="bi bi-currency-dollar"></i></div>
                <div>
                    <div class="admin-stat-value">$<%= stats.totalRevenue.toFixed(0) %>
                    </div>
                    <div class="admin-stat-label">Revenue</div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="admin-stat-card" style="--accent: #3498db;">
                <div class="admin-stat-icon"><i class="bi bi-people"></i></div>
                <div>
                    <div class="admin-stat-value">
                        <%= stats.totalUsers %>
                    </div>
                    <div class="admin-stat-label">Users</div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="admin-stat-card" style="--accent: #e74c3c;">
                <div class="admin-stat-icon"><i class="bi bi-arrow-repeat"></i></div>
                <div>
                    <div class="admin-stat-value">
                        <%= stats.activeSubs %>
                    </div>
                    <div class="admin-stat-label">Active Subs</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row g-4 mb-4">
        <div class="col-md-6 col-lg-3">
            <a href="/admin/dishes" class="admin-action-card">
                <i class="bi bi-egg-fried"></i>
                <span>Manage Dishes</span>
            </a>
        </div>
        <div class="col-md-6 col-lg-3">
            <a href="/admin/meal-plans" class="admin-action-card">
                <i class="bi bi-calendar-week"></i>
                <span>Meal Plans</span>
            </a>
        </div>
        <div class="col-md-6 col-lg-3">
            <a href="/admin/daily-specials" class="admin-action-card">
                <i class="bi bi-star-fill"></i>
                <span>Daily Specials</span>
            </a>
        </div>
        <div class="col-md-6 col-lg-3">
            <a href="/admin/orders" class="admin-action-card">
                <i class="bi bi-clipboard-check"></i>
                <span>All Orders</span>
            </a>
        </div>
    </div>

    <!-- Recent Orders Table -->
    <div class="glass-card">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Recent Orders</h5>
            <a href="/admin/orders" class="btn btn-sm btn-primary rounded-pill">View All</a>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Customer</th>
                        <th>Items</th>
                        <th>Total</th>
                        <th>Payment</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% recentOrders.forEach(order=> { %>
                        <tr>
                            <td class="fw-semibold">#<%= order._id.toString().slice(-6) %>
                            </td>
                            <td>
                                <%= order.user ? order.user.name : 'Unknown' %>
                            </td>
                            <td>
                                <%= order.items.length %> items
                            </td>
                            <td class="fw-bold text-primary">$<%= order.totalAmount.toFixed(2) %>
                            </td>
                            <td><span
                                    class="badge bg-<%= order.paymentStatus === 'paid' ? 'success' : 'warning' %> rounded-pill">
                                    <%= order.paymentStatus %>
                                </span></td>
                            <td><span
                                    class="badge bg-<%= order.orderStatus === 'delivered' ? 'success' : order.orderStatus === 'cancelled' ? 'danger' : 'warning' %> rounded-pill">
                                    <%= order.orderStatus %>
                                </span></td>
                            <td class="text-muted small">
                                <%= new Date(order.createdAt).toLocaleDateString() %>
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <button class="btn btn-outline-primary rounded-pill" data-bs-toggle="modal"
                                        data-bs-target="#statusModal<%= order._id %>">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                </div>
                                <!-- Status Modal -->
                                <div class="modal fade" id="statusModal<%= order._id %>" tabindex="-1">
                                    <div class="modal-dialog">
                                        <div class="modal-content rounded-4">
                                            <div class="modal-header border-0">
                                                <h5 class="modal-title">Update Order #<%= order._id.toString().slice(-6)
                                                        %>
                                                </h5>
                                                <button type="button" class="btn-close"
                                                    data-bs-dismiss="modal"></button>
                                            </div>
                                            <form action="/admin/orders/<%= order._id %>/status" method="post">
                                                <div class="modal-body">
                                                    <div class="mb-3">
                                                        <label class="form-label fw-semibold">Order Status</label>
                                                        <select name="orderStatus" class="form-select rounded-3">
                                                            <option value="pending" <%=order.orderStatus==='pending'
                                                                ?'selected':'' %>>Pending</option>
                                                            <option value="confirmed" <%=order.orderStatus==='confirmed'
                                                                ?'selected':'' %>>Confirmed</option>
                                                            <option value="preparing" <%=order.orderStatus==='preparing'
                                                                ?'selected':'' %>>Preparing</option>
                                                            <option value="delivered" <%=order.orderStatus==='delivered'
                                                                ?'selected':'' %>>Delivered</option>
                                                            <option value="cancelled" <%=order.orderStatus==='cancelled'
                                                                ?'selected':'' %>>Cancelled</option>
                                                        </select>
                                                    </div>
                                                    <div class="mb-3">
                                                        <label class="form-label fw-semibold">Note</label>
                                                        <input type="text" name="note" class="form-control rounded-3"
                                                            placeholder="Optional note...">
                                                    </div>
                                                </div>
                                                <div class="modal-footer border-0">
                                                    <button type="submit"
                                                        class="btn btn-primary rounded-pill px-4">Update</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>