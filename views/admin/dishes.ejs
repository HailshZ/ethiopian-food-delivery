<div class="container-fluid py-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="bi bi-egg-fried me-2"></i>Manage Dishes</h2>
        <div>
            <button class="btn btn-primary rounded-pill" data-bs-toggle="modal" data-bs-target="#addDishModal">
                <i class="bi bi-plus-lg me-1"></i>Add Dish
            </button>
            <a href="/admin" class="btn btn-outline-secondary rounded-pill ms-2"><i
                    class="bi bi-arrow-left me-1"></i>Dashboard</a>
        </div>
    </div>

    <div class="glass-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Image</th>
                        <th>Name</th>
                        <th>Name (AM)</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% dishes.forEach(dish=> { %>
                        <tr>
                            <td><img src="<%= dish.imageUrl %>" class="rounded-3"
                                    style="width:50px;height:50px;object-fit:cover;"
                                    onerror="this.src='https://images.unsplash.com/photo-1604329760661-e71dc83f8f26?w=100'">
                            </td>
                            <td class="fw-semibold">
                                <%= dish.name %>
                            </td>
                            <td>
                                <%= dish.nameAm %>
                            </td>
                            <td><span class="badge bg-light text-dark rounded-pill">
                                    <%= dish.category %>
                                </span></td>
                            <td class="fw-bold text-primary">$<%= dish.price.toFixed(2) %>
                            </td>
                            <td>
                                <span class="badge bg-<%= dish.isAvailable ? 'success' : 'secondary' %> rounded-pill">
                                    <%= dish.isAvailable ? 'Available' : 'Hidden' %>
                                </span>
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary rounded-pill me-1" data-bs-toggle="modal"
                                    data-bs-target="#editDish<%= dish._id %>">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <form action="/admin/dishes/<%= dish._id %>/delete" method="post" class="d-inline"
                                    onsubmit="return confirm('Delete this dish?')">
                                    <button class="btn btn-sm btn-outline-danger rounded-pill"><i
                                            class="bi bi-trash3"></i></button>
                                </form>

                                <!-- Edit Modal -->
                                <div class="modal fade" id="editDish<%= dish._id %>" tabindex="-1">
                                    <div class="modal-dialog modal-lg">
                                        <div class="modal-content rounded-4">
                                            <div class="modal-header border-0">
                                                <h5 class="modal-title">Edit: <%= dish.name %>
                                                </h5><button type="button" class="btn-close"
                                                    data-bs-dismiss="modal"></button>
                                            </div>
                                            <form action="/admin/dishes/<%= dish._id %>/update" method="post">
                                                <div class="modal-body">
                                                    <div class="row g-3">
                                                        <div class="col-md-6"><label class="form-label">Name
                                                                (EN)</label><input name="name"
                                                                class="form-control rounded-3" value="<%= dish.name %>"
                                                                required></div>
                                                        <div class="col-md-6"><label class="form-label">Name
                                                                (AM)</label><input name="nameAm"
                                                                class="form-control rounded-3"
                                                                value="<%= dish.nameAm %>"></div>
                                                        <div class="col-12"><label class="form-label">Description
                                                                (EN)</label><textarea name="description"
                                                                class="form-control rounded-3"
                                                                rows="2"><%= dish.description %></textarea></div>
                                                        <div class="col-12"><label class="form-label">Description
                                                                (AM)</label><textarea name="descriptionAm"
                                                                class="form-control rounded-3"
                                                                rows="2"><%= dish.descriptionAm %></textarea></div>
                                                        <div class="col-md-4"><label class="form-label">Price
                                                                ($)</label><input name="price" type="number" step="0.01"
                                                                class="form-control rounded-3" value="<%= dish.price %>"
                                                                required></div>
                                                        <div class="col-md-4"><label
                                                                class="form-label">Category</label><select
                                                                name="category" class="form-select rounded-3">
                                                                <option value="food" <%=dish.category==='food'
                                                                    ?'selected':'' %>>Food</option>
                                                                <option value="coffee" <%=dish.category==='coffee'
                                                                    ?'selected':'' %>>Coffee</option>
                                                                <option value="drink" <%=dish.category==='drink'
                                                                    ?'selected':'' %>>Drink</option>
                                                            </select></div>
                                                        <div class="col-md-4"><label
                                                                class="form-label">Available</label>
                                                            <div class="form-check form-switch mt-2"><input
                                                                    class="form-check-input" type="checkbox"
                                                                    name="isAvailable" <%=dish.isAvailable ? 'checked'
                                                                    : '' %>></div>
                                                        </div>
                                                        <div class="col-12"><label class="form-label">Image
                                                                URL</label><input name="imageUrl"
                                                                class="form-control rounded-3"
                                                                value="<%= dish.imageUrl %>"></div>
                                                    </div>
                                                </div>
                                                <div class="modal-footer border-0"><button type="submit"
                                                        class="btn btn-primary rounded-pill px-4">Save Changes</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Add Dish Modal -->
<div class="modal fade" id="addDishModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content rounded-4">
            <div class="modal-header border-0">
                <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>Add New Dish</h5><button type="button"
                    class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form action="/admin/dishes" method="post">
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6"><label class="form-label">Name (EN)</label><input name="name"
                                class="form-control rounded-3" required></div>
                        <div class="col-md-6"><label class="form-label">Name (AM)</label><input name="nameAm"
                                class="form-control rounded-3" required></div>
                        <div class="col-12"><label class="form-label">Description (EN)</label><textarea
                                name="description" class="form-control rounded-3" rows="2" required></textarea></div>
                        <div class="col-12"><label class="form-label">Description (AM)</label><textarea
                                name="descriptionAm" class="form-control rounded-3" rows="2" required></textarea></div>
                        <div class="col-md-4"><label class="form-label">Price ($)</label><input name="price"
                                type="number" step="0.01" class="form-control rounded-3" required></div>
                        <div class="col-md-4"><label class="form-label">Category</label><select name="category"
                                class="form-select rounded-3">
                                <option value="food">Food</option>
                                <option value="coffee">Coffee</option>
                                <option value="drink">Drink</option>
                            </select></div>
                        <div class="col-md-4"><label class="form-label">Image URL</label><input name="imageUrl"
                                class="form-control rounded-3" placeholder="https://..."></div>
                    </div>
                </div>
                <div class="modal-footer border-0"><button type="submit" class="btn btn-primary rounded-pill px-4">Add
                        Dish</button></div>
            </form>
        </div>
    </div>
</div>