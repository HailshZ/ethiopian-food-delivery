<div class="container-fluid py-4 px-4">
    <a href="/admin/meal-plans" class="btn btn-outline-secondary rounded-pill mb-4"><i
            class="bi bi-arrow-left me-1"></i>Back to Plans</a>
    <h2 class="fw-bold mb-4"><i class="bi bi-calendar-week me-2"></i>
        <%= plan ? 'Edit' : 'Create' %> Meal Plan
    </h2>

    <form action="<%= plan ? '/admin/meal-plans/' + plan.id + '/update' : '/admin/meal-plans' %>" method="post">
        <div class="row g-4">
            <!-- Plan Info -->
            <div class="col-lg-4">
                <div class="glass-card">
                    <h5 class="mb-3">Plan Details</h5>
                    <div class="mb-3"><label class="form-label">Name (EN)</label><input name="name"
                            class="form-control rounded-3" value="<%= plan ? plan.name : '' %>" required></div>
                    <div class="mb-3"><label class="form-label">Name (AM)</label><input name="nameAm"
                            class="form-control rounded-3" value="<%= plan ? plan.nameAm : '' %>"></div>
                    <div class="mb-3"><label class="form-label">Description (EN)</label><textarea name="description"
                            class="form-control rounded-3" rows="2"><%= plan ? plan.description : '' %></textarea></div>
                    <div class="mb-3"><label class="form-label">Description (AM)</label><textarea name="descriptionAm"
                            class="form-control rounded-3" rows="2"><%= plan ? plan.descriptionAm : '' %></textarea>
                    </div>
                    <div class="row g-2">
                        <div class="col-6"><label class="form-label">Price ($)</label><input name="price" type="number"
                                step="0.01" class="form-control rounded-3" value="<%= plan ? plan.price : '' %>"
                                required></div>
                        <div class="col-6"><label class="form-label">Duration</label><select name="duration"
                                class="form-select rounded-3">
                                <option value="weekly" <%=plan && plan.duration==='weekly' ? 'selected' : '' %>>Weekly
                                </option>
                                <option value="monthly" <%=plan && plan.duration==='monthly' ? 'selected' : '' %>
                                    >Monthly</option>
                            </select></div>
                    </div>
                    <div class="mb-3 mt-3"><label class="form-label">Image URL</label><input name="imageUrl"
                            class="form-control rounded-3" value="<%= plan ? plan.imageUrl : '' %>"></div>
                    <% if (plan) { %>
                        <div class="form-check form-switch mb-3"><input class="form-check-input" type="checkbox"
                                name="isActive" <%=plan.isActive ? 'checked' : '' %>><label
                                class="form-check-label">Active</label></div>
                        <% } %>
                </div>
            </div>

            <!-- Daily Meals -->
            <div class="col-lg-8">
                <div class="glass-card">
                    <h5 class="mb-3">Weekly Meals</h5>
                    <p class="text-muted small mb-4">Assign dishes and meal types for each day. Click "Add Meal" to add
                        multiple meals per day.</p>

                    <% const dayNames=['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday']; %>
                        <% const dayKeys=['monday','tuesday','wednesday','thursday','friday','saturday','sunday']; %>
                            <% dayKeys.forEach((day, i)=> { %>
                                <div class="day-section mb-4">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <h6 class="mb-0"><i class="bi bi-calendar-day me-1 text-primary"></i>
                                            <%= dayNames[i] %>
                                        </h6>
                                        <button type="button"
                                            class="btn btn-sm btn-outline-primary rounded-pill add-meal-btn"
                                            data-day="<%= day %>">
                                            <i class="bi bi-plus me-1"></i>Add Meal
                                        </button>
                                    </div>
                                    <div id="meals-<%= day %>" class="meals-container">
                                        <% if (plan && plan.meals && plan.meals[day] && plan.meals[day].length> 0) { %>
                                            <% plan.meals[day].forEach((slot, si)=> { %>
                                                <div class="meal-row d-flex gap-2 mb-2 align-items-center">
                                                    <select name="<%= day %>_dishes"
                                                        class="form-select form-select-sm rounded-3">
                                                        <option value="">-- Select Dish --</option>
                                                        <% dishes.forEach(d=> { %>
                                                            <option value="<%= d.id %>" <%=slot.dish &&
                                                                slot.dish.toString()===d.id.toString() ? 'selected'
                                                                : '' %>><%= d.name %> ($<%= d.price.toFixed(2) %>)
                                                            </option>
                                                            <% }) %>
                                                    </select>
                                                    <select name="<%= day %>_mealTypes"
                                                        class="form-select form-select-sm rounded-3"
                                                        style="max-width:140px;">
                                                        <option value="breakfast" <%=slot.mealType==='breakfast'
                                                            ?'selected':'' %>>Breakfast</option>
                                                        <option value="lunch" <%=slot.mealType==='lunch' ?'selected':''
                                                            %>>Lunch</option>
                                                        <option value="dinner" <%=slot.mealType==='dinner'
                                                            ?'selected':'' %>>Dinner</option>
                                                    </select>
                                                    <button type="button"
                                                        class="btn btn-sm btn-outline-danger rounded-pill remove-meal"><i
                                                            class="bi bi-x"></i></button>
                                                </div>
                                                <% }) %>
                                                    <% } %>
                                    </div>
                                </div>
                                <% }) %>
                </div>

                <button type="submit" class="btn btn-primary btn-lg rounded-pill w-100 mt-3 py-3">
                    <i class="bi bi-check-lg me-2"></i>
                    <%= plan ? 'Update' : 'Create' %> Meal Plan
                </button>
            </div>
        </div>
    </form>
</div>

<script>
    // Template for adding a new meal row
    function createMealRow(day) {
        const dishes = <% - JSON.stringify(dishes.map(d => ({ id: d.id, name: d.name, price: d.price }))) %>;
        const div = document.createElement('div');
        div.className = 'meal-row d-flex gap-2 mb-2 align-items-center';
        let opts = '<option value="">-- Select Dish --</option>';
        dishes.forEach(d => { opts += `<option value="${d.id}">${d.name} ($${d.price.toFixed(2)})</option>`; });
        div.innerHTML = `
    <select name="${day}_dishes" class="form-select form-select-sm rounded-3">${opts}</select>
    <select name="${day}_mealTypes" class="form-select form-select-sm rounded-3" style="max-width:140px;">
      <option value="breakfast">Breakfast</option>
      <option value="lunch" selected>Lunch</option>
      <option value="dinner">Dinner</option>
    </select>
    <button type="button" class="btn btn-sm btn-outline-danger rounded-pill remove-meal"><i class="bi bi-x"></i></button>
  `;
        return div;
    }

    document.querySelectorAll('.add-meal-btn').forEach(btn => {
        btn.addEventListener('click', function () {
            const day = this.dataset.day;
            document.getElementById('meals-' + day).appendChild(createMealRow(day));
        });
    });

    document.addEventListener('click', function (e) {
        if (e.target.closest('.remove-meal')) {
            e.target.closest('.meal-row').remove();
        }
    });
</script>