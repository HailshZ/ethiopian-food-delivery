<div class="container-fluid py-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="bi bi-star-fill me-2"></i>Daily Specials</h2>
        <div>
            <button class="btn btn-primary rounded-pill" data-bs-toggle="modal" data-bs-target="#addSpecialModal"><i
                    class="bi bi-plus-lg me-1"></i>Add Special</button>
            <a href="/admin" class="btn btn-outline-secondary rounded-pill ms-2"><i
                    class="bi bi-arrow-left me-1"></i>Dashboard</a>
        </div>
    </div>

    <% const dayLabels=['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday']; %>

        <div class="glass-card">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Day</th>
                            <th>Dish</th>
                            <th>Regular Price</th>
                            <th>Special Price</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% specials.forEach(special=> { %>
                            <tr>
                                <td><span class="badge bg-primary rounded-pill">
                                        <%= dayLabels[special.dayOfWeek] %>
                                    </span></td>
                                <td class="fw-semibold">
                                    <%= special.dish ? special.dish.name : 'Unknown' %>
                                </td>
                                <td class="text-muted">
                                    <%= special.dish ? '$' + special.dish.price.toFixed(2) : '-' %>
                                </td>
                                <td class="fw-bold text-success">$<%= special.specialPrice.toFixed(2) %>
                                </td>
                                <td><span
                                        class="badge bg-<%= special.isActive ? 'success' : 'secondary' %> rounded-pill">
                                        <%= special.isActive ? 'Active' : 'Inactive' %>
                                    </span></td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary rounded-pill me-1"
                                        data-bs-toggle="modal" data-bs-target="#editSpecial<%= special.id %>"><i
                                            class="bi bi-pencil"></i></button>
                                    <form action="/admin/daily-specials/<%= special.id %>/delete" method="post"
                                        class="d-inline" onsubmit="return confirm('Delete?')">
                                        <button class="btn btn-sm btn-outline-danger rounded-pill"><i
                                                class="bi bi-trash3"></i></button>
                                    </form>

                                    <!-- Edit Modal -->
                                    <div class="modal fade" id="editSpecial<%= special.id %>" tabindex="-1">
                                        <div class="modal-dialog">
                                            <div class="modal-content rounded-4">
                                                <div class="modal-header border-0">
                                                    <h5>Edit Special</h5><button type="button" class="btn-close"
                                                        data-bs-dismiss="modal"></button>
                                                </div>
                                                <form action="/admin/daily-specials/<%= special.id %>/update"
                                                    method="post">
                                                    <div class="modal-body">
                                                        <div class="mb-3"><label class="form-label">Day</label><select
                                                                name="dayOfWeek" class="form-select rounded-3">
                                                                <% dayLabels.forEach((d, idx)=> { %><option
                                                                        value="<%= idx %>"
                                                                        <%=special.dayOfWeek===idx?'selected':'' %>><%=
                                                                            d %>
                                                                    </option>
                                                                    <% }) %>
                                                            </select></div>
                                                        <div class="mb-3"><label class="form-label">Dish</label><select
                                                                name="dish" class="form-select rounded-3">
                                                                <% dishes.forEach(d=> { %><option value="<%= d.id %>"
                                                                        <%=special.dish &&
                                                                        special.dish.id.toString()===d.id.toString()?'selected':''
                                                                        %>><%= d.name %>
                                                                    </option>
                                                                    <% }) %>
                                                            </select></div>
                                                        <div class="mb-3"><label class="form-label">Special Price
                                                                ($)</label><input name="specialPrice" type="number"
                                                                step="0.01" class="form-control rounded-3"
                                                                value="<%= special.specialPrice %>" required></div>
                                                        <div class="mb-3"><label class="form-label">Description
                                                                (EN)</label><input name="description"
                                                                class="form-control rounded-3"
                                                                value="<%= special.description %>"></div>
                                                        <div class="mb-3"><label class="form-label">Description
                                                                (AM)</label><input name="descriptionAm"
                                                                class="form-control rounded-3"
                                                                value="<%= special.descriptionAm %>"></div>
                                                        <div class="form-check form-switch"><input
                                                                class="form-check-input" type="checkbox" name="isActive"
                                                                <%=special.isActive ? 'checked' : '' %>><label
                                                                class="form-check-label">Active</label></div>
                                                    </div>
                                                    <div class="modal-footer border-0"><button type="submit"
                                                            class="btn btn-primary rounded-pill px-4">Save</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
</div>

<!-- Add Special Modal -->
<div class="modal fade" id="addSpecialModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content rounded-4">
            <div class="modal-header border-0">
                <h5><i class="bi bi-plus-circle me-2"></i>Add Daily Special</h5><button type="button" class="btn-close"
                    data-bs-dismiss="modal"></button>
            </div>
            <form action="/admin/daily-specials" method="post">
                <div class="modal-body">
                    <div class="mb-3"><label class="form-label">Day</label><select name="dayOfWeek"
                            class="form-select rounded-3">
                            <% dayLabels.forEach((d, idx)=> { %><option value="<%= idx %>">
                                    <%= d %>
                                </option>
                                <% }) %>
                        </select></div>
                    <div class="mb-3"><label class="form-label">Dish</label><select name="dish"
                            class="form-select rounded-3">
                            <% dishes.forEach(d=> { %><option value="<%= d.id %>">
                                    <%= d.name %> ($<%= d.price.toFixed(2) %>)
                                </option>
                                <% }) %>
                        </select></div>
                    <div class="mb-3"><label class="form-label">Special Price ($)</label><input name="specialPrice"
                            type="number" step="0.01" class="form-control rounded-3" required></div>
                    <div class="mb-3"><label class="form-label">Description (EN)</label><input name="description"
                            class="form-control rounded-3"></div>
                    <div class="mb-3"><label class="form-label">Description (AM)</label><input name="descriptionAm"
                            class="form-control rounded-3"></div>
                </div>
                <div class="modal-footer border-0"><button type="submit" class="btn btn-primary rounded-pill px-4">Add
                        Special</button></div>
            </form>
        </div>
    </div>
</div>