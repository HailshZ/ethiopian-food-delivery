<div class="container py-4">
  <h1 class="text-center mb-5" style="color: #078930; font-weight: 700; position: relative;">
    <%= t('menu') %>
    <span style="display: block; width: 80px; height: 4px; background: #fcdd09; margin: 10px auto 0; border-radius: 2px;"></span>
  </h1>

  <% if (!dishes || dishes.length === 0) { %>
    <div class="alert alert-warning text-center py-5">
      <i class="bi bi-exclamation-triangle" style="font-size: 3rem; color: #da121a;"></i>
      <h4 class="mt-3">No dishes available</h4>
      <p>Please run the seed route to populate the menu.</p>
    </div>
  <% } else { %>
    <div class="row g-4">
      <% dishes.forEach(dish => { %>
        <div class="col-md-6 col-lg-4">
          <div class="card h-100" style="border: none; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); transition: transform 0.3s, box-shadow 0.3s;">
            <img src="<%= dish.imageUrl || 'https://via.placeholder.com/300x200?text=Ethiopian+Food' %>" 
                 class="card-img-top" alt="<%= dish.name %>" 
                 style="height: 200px; object-fit: cover; border-radius: 20px 20px 0 0;"
                 onerror="this.src='https://via.placeholder.com/300x200?text=No+Image'">
            <div class="card-body d-flex flex-column" style="padding: 1.5rem;">
              <h5 class="card-title" style="font-weight: 700; color: #2c3e50;">
                <%= currentLanguage === 'en' ? dish.name : (dish.nameAm || dish.name) %>
              </h5>
              <p class="card-text flex-grow-1" style="color: #5d6d7e; font-size: 0.95rem;">
                <%= currentLanguage === 'en' ? dish.description : (dish.descriptionAm || dish.description) %>
              </p>
              <div class="d-flex justify-content-between align-items-center mt-3">
                <span class="price" style="font-size: 1.3rem; font-weight: 700; color: #078930;"><%= (dish.price) %></span>
                <form action="/cart/add/<%= dish._id %>" method="post">
                  <button type="submit" class="btn text-white" style="background: linear-gradient(135deg, #078930, #056b24); border: none; border-radius: 50px; padding: 0.5rem 1.5rem; font-weight: 600;">
                    <i class="bi bi-cart-plus me-2"></i><%= t('add_to_cart') %>
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>