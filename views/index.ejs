  <div class="row g-4">
    <div class="col-md-4">
      <div class="card text-center" style="border: none; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05);">
        <div class="card-body" style="padding: 2rem;">
          <i class="bi bi-cup-hot-fill" style="font-size: 3rem; color: #078930;"></i>
          <h5 class="mt-3" style="font-weight: 700;">Ethiopian Coffee</h5>
          <p style="color: #5d6d7e;">Traditional coffee ceremony</p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card text-center" style="border: none; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05);">
        <div class="card-body" style="padding: 2rem;">
          <i class="bi bi-egg-fried" style="font-size: 3rem; color: #078930;"></i>
          <h5 class="mt-3" style="font-weight: 700;">Doro Wat</h5>
          <p style="color: #5d6d7e;">Spicy chicken stew</p>
