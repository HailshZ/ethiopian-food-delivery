<!-- Hero Section -->
<div style="background: linear-gradient(135deg, #078930 0%, #056b24 100%); color: white; padding: 4rem 0; margin-bottom: 3rem;">
  <div class="container text-center">
    <h1 class="display-4 fw-bold mb-4"><%= t('welcome') %></h1>
    <p class="lead mb-4" style="font-size: 1.3rem;"><%= t('description') %></p>
    <a href="/menu" class="btn btn-light btn-lg" style="border-radius: 50px; padding: 0.75rem 2.5rem; font-weight: 600; background: #fcdd09; color: #2c3e50; border: none;">
      <i class="bi bi-bag me-2"></i><%= t('order_now') %>
    </a>
  </div>
</div>

<!-- Featured Categories or Something -->
