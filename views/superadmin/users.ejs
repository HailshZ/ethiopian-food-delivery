<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-people-fill me-2 text-primary"></i>User Management</h2>
            <p class="text-muted mb-0">Manage user roles and permissions</p>
        </div>
        <a href="/superadmin/settings" class="btn btn-outline-secondary rounded-pill"><i
                class="bi bi-arrow-left me-1"></i> Back to Settings</a>
    </div>

    <div class="glass-card">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Email</th>
                        <th>Current Role</th>
                        <th>Joined</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(user=> { %>
                        <tr style="animation: fadeInUp 0.3s ease;">
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="user-avatar" style="width: 36px; height: 36px; font-size: 0.8rem;">
                                        <%= user.name.charAt(0).toUpperCase() %>
                                    </div>
                                    <strong>
                                        <%= user.name %>
                                    </strong>
                                </div>
                            </td>
                            <td class="text-muted">
                                <%= user.email %>
                            </td>
                            <td>
                                <% if (user.role==='superadmin' ) { %>
                                    <span class="badge bg-danger rounded-pill px-3 py-2"><i
                                            class="bi bi-shield-lock me-1"></i>Super Admin</span>
                                    <% } else if (user.role==='admin' ) { %>
                                        <span class="badge bg-warning text-dark rounded-pill px-3 py-2"><i
                                                class="bi bi-shield me-1"></i>Admin</span>
                                        <% } else { %>
                                            <span class="badge bg-secondary rounded-pill px-3 py-2"><i
                                                    class="bi bi-person me-1"></i>User</span>
                                            <% } %>
                            </td>
                            <td class="text-muted small">
                                <%= new Date(user.createdAt).toLocaleDateString() %>
                            </td>
                            <td>
                                <form action="/superadmin/user/<%= user._id %>/role" method="POST"
                                    class="d-flex gap-2 align-items-center">
                                    <select name="role" class="form-select form-select-sm rounded-pill"
                                        style="width: auto;">
                                        <option value="user" <%=user.role==='user' ? 'selected' : '' %>>User</option>
                                        <option value="admin" <%=user.role==='admin' ? 'selected' : '' %>>Admin</option>
                                        <option value="superadmin" <%=user.role==='superadmin' ? 'selected' : '' %>
                                            >Super Admin</option>
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-primary rounded-pill px-3">
                                        <i class="bi bi-check-lg"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>