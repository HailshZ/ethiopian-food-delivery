<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-gear-fill me-2 text-primary"></i>System Settings</h2>
            <p class="text-muted mb-0">Configure your platform's core settings</p>
        </div>
        <a href="/admin" class="btn btn-outline-secondary rounded-pill"><i class="bi bi-arrow-left me-1"></i> Back to
            Admin</a>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <form action="/superadmin/settings" method="POST">
                <!-- Branding -->
                <div class="glass-card mb-4">
                    <h5 class="fw-bold mb-3"><i class="bi bi-building me-2 text-primary"></i>Branding</h5>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">System Name</label>
                            <input type="text" name="systemName" class="form-control rounded-3"
                                value="<%= sysSettings.systemName %>">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Currency</label>
                            <input type="text" name="currency" class="form-control rounded-3"
                                value="<%= sysSettings.currency %>">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Currency Symbol</label>
                            <input type="text" name="currencySymbol" class="form-control rounded-3"
                                value="<%= sysSettings.currencySymbol %>">
                        </div>
                    </div>
                </div>

                <!-- Contact Info -->
                <div class="glass-card mb-4">
                    <h5 class="fw-bold mb-3"><i class="bi bi-telephone me-2 text-primary"></i>Contact Information</h5>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Contact Email</label>
                            <input type="email" name="contactEmail" class="form-control rounded-3"
                                value="<%= sysSettings.contactEmail %>">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Contact Phone</label>
                            <input type="text" name="contactPhone" class="form-control rounded-3"
                                value="<%= sysSettings.contactPhone %>">
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Address</label>
                            <input type="text" name="address" class="form-control rounded-3"
                                value="<%= sysSettings.address %>">
                        </div>
                    </div>
                </div>

                <!-- Order Settings -->
                <div class="glass-card mb-4">
                    <h5 class="fw-bold mb-3"><i class="bi bi-cart-check me-2 text-primary"></i>Order Settings</h5>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Delivery Fee (<%= sysSettings.currencySymbol %>
                                    )</label>
                            <input type="number" step="0.01" name="deliveryFee" class="form-control rounded-3"
                                value="<%= sysSettings.deliveryFee %>">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Minimum Order Amount (<%= sysSettings.currencySymbol
                                    %>)</label>
                            <input type="number" step="0.01" name="minOrderAmount" class="form-control rounded-3"
                                value="<%= sysSettings.minOrderAmount %>">
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5">
                    <i class="bi bi-check-lg me-2"></i>Save Settings
                </button>
            </form>
        </div>

        <!-- Quick Links -->
        <div class="col-lg-4">
            <div class="glass-card mb-4">
                <h5 class="fw-bold mb-3"><i class="bi bi-lightning me-2 text-warning"></i>Quick Actions</h5>
                <div class="d-grid gap-2">
                    <a href="/superadmin/users" class="btn btn-outline-primary rounded-pill"><i
                            class="bi bi-people me-2"></i>Manage Users & Roles</a>
                    <a href="/admin" class="btn btn-outline-secondary rounded-pill"><i
                            class="bi bi-speedometer2 me-2"></i>Admin Dashboard</a>
                    <a href="/admin/promos" class="btn btn-outline-success rounded-pill"><i
                            class="bi bi-tags me-2"></i>Promo Codes</a>
                </div>
            </div>

            <div class="glass-card">
                <h5 class="fw-bold mb-3"><i class="bi bi-info-circle me-2 text-info"></i>Current Config</h5>
                <ul class="list-unstyled mb-0">
                    <li class="mb-2"><span class="text-muted">Name:</span> <strong>
                            <%= sysSettings.systemName %>
                        </strong></li>
                    <li class="mb-2"><span class="text-muted">Currency:</span> <strong>
                            <%= sysSettings.currencySymbol %>
                        </strong></li>
                    <li class="mb-2"><span class="text-muted">Delivery Fee:</span> <strong>
                            <%= sysSettings.currencySymbol %>
                                <%= sysSettings.deliveryFee %>
                        </strong></li>
                    <li class="mb-0"><span class="text-muted">Min Order:</span> <strong>
                            <%= sysSettings.currencySymbol %>
                                <%= sysSettings.minOrderAmount %>
                        </strong></li>
                </ul>
            </div>
        </div>
    </div>
</div>