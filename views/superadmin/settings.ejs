<div class="container py-4">
    <h1 class="mb-4" style="color: #ff6b6b;"><i class="bi bi-shield-lock me-2"></i>System Settings</h1>

    <form action="/superadmin/settings" method="post">
        <div class="row g-4">
            <!-- General -->
            <div class="col-md-6">
                <div class="card shadow-sm border-0" style="border-radius: 15px;">
                    <div class="card-header bg-white">
                        <h5 class="mb-0"><i class="bi bi-gear me-2"></i>General</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">System Name</label>
                            <input type="text" name="systemName" class="form-control"
                                value="<%= sysSettings.systemName %>">
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Contact Email</label>
                            <input type="email" name="contactEmail" class="form-control"
                                value="<%= sysSettings.contactEmail %>">
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Contact Phone</label>
                            <input type="text" name="contactPhone" class="form-control"
                                value="<%= sysSettings.contactPhone %>">
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Address</label>
                            <input type="text" name="address" class="form-control" value="<%= sysSettings.address %>">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Currency -->
            <div class="col-md-6">
                <div class="card shadow-sm border-0" style="border-radius: 15px;">
                    <div class="card-header bg-white">
                        <h5 class="mb-0"><i class="bi bi-currency-exchange me-2"></i>Currency & Pricing</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Currency</label>
                                <input type="text" name="currency" class="form-control"
                                    value="<%= sysSettings.currency %>">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Symbol</label>
                                <input type="text" name="currencySymbol" class="form-control"
                                    value="<%= sysSettings.currencySymbol %>">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Position</label>
                                <select name="currencyPosition" class="form-select">
                                    <option value="left" <%=sysSettings.currencyPosition==='left' ? 'selected' : '' %>
                                        >Left (ETB 100)</option>
                                    <option value="right" <%=sysSettings.currencyPosition==='right' ? 'selected' : '' %>
                                        >Right (100 ETB)</option>
                                </select>
                            </div>
                        </div>
                        <div class="mt-3 p-2 bg-light rounded text-center">
                            <small class="text-muted">Preview:</small>
                            <strong class="ms-2" id="currency-preview">
                                <%= sysSettings.currencyPosition==='right' ? '100.00 ' + sysSettings.currencySymbol :
                                    sysSettings.currencySymbol + ' 100.00' %>
                            </strong>
                        </div>
                        <hr>
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Base Delivery Fee</label>
                                <input type="number" name="baseDeliveryFee" class="form-control" step="0.01"
                                    value="<%= sysSettings.baseDeliveryFee %>">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Fee per KM</label>
                                <input type="number" name="deliveryFeePerKm" class="form-control" step="0.01"
                                    value="<%= sysSettings.deliveryFeePerKm %>">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Min Order</label>
                                <input type="number" name="minOrderAmount" class="form-control" step="0.01"
                                    value="<%= sysSettings.minOrderAmount %>">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Restaurant Location -->
            <div class="col-12">
                <div class="card shadow-sm border-0" style="border-radius: 15px;">
                    <div class="card-header bg-white">
                        <h5 class="mb-0"><i class="bi bi-geo-alt me-2"></i>Restaurant Location (for delivery fee
                            calculation)</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Latitude</label>
                                <input type="number" name="restaurantLat" class="form-control" step="0.0001"
                                    value="<%= sysSettings.restaurantLat ? sysSettings.restaurantLat : 9.0192 %>">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Longitude</label>
                                <input type="number" name="restaurantLng" class="form-control" step="0.0001"
                                    value="<%= sysSettings.restaurantLng ? sysSettings.restaurantLng : 38.7525 %>">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-danger rounded-pill px-5 py-2"><i
                    class="bi bi-check2-circle me-2"></i>Save Settings</button>
            <a href="/superadmin/users" class="btn btn-outline-primary rounded-pill ms-2"><i
                    class="bi bi-people me-1"></i>Manage Users</a>
        </div>
    </form>
</div>

<script>
    // Live currency preview
    document.querySelectorAll('[name="currencySymbol"], [name="currencyPosition"]').forEach(el => {
        el.addEventListener('change', updatePreview);
        el.addEventListener('input', updatePreview);
    });
    function updatePreview() {
        const sym = document.querySelector('[name="currencySymbol"]').value;
        const pos = document.querySelector('[name="currencyPosition"]').value;
        document.getElementById('currency-preview').textContent = pos === 'right' ? '100.00 ' + sym : sym + ' 100.00';
    }
</script>