<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-5">
      <div class="glass-card auth-card">
        <div class="text-center mb-4">
          <div class="auth-icon"><i class="bi bi-box-arrow-in-right"></i></div>
          <h3 class="fw-bold">
            <%= t('login') %>
          </h3>
          <p class="text-muted">
            <%= t('welcome_back') %>
          </p>
        </div>

        <% if (typeof errors !=='undefined' && errors && errors.length> 0) { %>
          <% errors.forEach(err=> { %>
            <div class="alert alert-danger rounded-3">
              <%= err.msg %>
            </div>
            <% }) %>
              <% } %>

                <form action="/login" method="post">
                  <div class="mb-3">
                    <label class="form-label fw-semibold"><i class="bi bi-envelope me-1"></i>
                      <%= t('email') %>
                    </label>
                    <input type="email" name="email" class="form-control rounded-3 py-2"
                      placeholder="<%= t('email_placeholder') %>" required>
                  </div>
                  <div class="mb-4">
                    <label class="form-label fw-semibold"><i class="bi bi-lock me-1"></i>
                      <%= t('password') %>
                    </label>
                    <input type="password" name="password" class="form-control rounded-3 py-2"
                      placeholder="<%= t('password_placeholder') %>" required>
                  </div>
                  <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-bold mb-3">
                    <i class="bi bi-box-arrow-in-right me-2"></i>
                    <%= t('login') %>
                  </button>
                  <p class="text-center text-muted mb-0">
                    <%= t('dont_have_account') %> <a href="/register" class="text-primary fw-semibold">
                        <%= t('register') %>
                      </a>
                  </p>
                </form>
      </div>
    </div>
  </div>
</div>