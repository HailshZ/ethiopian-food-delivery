<div class="container py-5">
  <div class="row g-4">
    <!-- Profile Card -->
    <div class="col-lg-4">
      <div class="glass-card text-center">
        <div class="profile-avatar mx-auto mb-3">
          <span>
            <%= user.name.charAt(0).toUpperCase() %>
          </span>
        </div>
        <h4 class="fw-bold">
          <%= user.name %>
        </h4>
        <p class="text-muted">
          <%= user.email %>
        </p>
        <div class="d-flex justify-content-center gap-4 mt-3">
          <div class="text-center">
            <div class="h5 text-primary mb-0">
              <%= orders.length %>
            </div>
            <small class="text-muted">
              <%= t('orders') %>
            </small>
          </div>
          <div class="text-center">
            <div class="h5 text-primary mb-0">$<%= totalSpent.toFixed(0) %>
            </div>
            <small class="text-muted">
              <%= t('spent') %>
            </small>
          </div>
        </div>
      </div>
    </div>

    <!-- Info & Orders -->
    <div class="col-lg-8">
      <div class="glass-card mb-4">
        <h5 class="mb-3"><i class="bi bi-person me-2 text-primary"></i>
          <%= t('personal_info') %>
        </h5>
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label text-muted small">
              <%= t('name') %>
            </label>
            <p class="fw-semibold mb-0">
              <%= user.name %>
            </p>
          </div>
          <div class="col-md-6">
            <label class="form-label text-muted small">
              <%= t('email') %>
            </label>
            <p class="fw-semibold mb-0">
              <%= user.email %>
            </p>
          </div>
          <div class="col-md-6">
            <label class="form-label text-muted small">
              <%= t('phone') %>
            </label>
            <p class="fw-semibold mb-0">
              <%= user.phone || t('not_provided') %>
            </p>
          </div>
          <div class="col-md-6">
            <label class="form-label text-muted small">
              <%= t('member_since') %>
            </label>
            <p class="fw-semibold mb-0">
              <%= new Date(user.createdAt).toLocaleDateString() %>
            </p>
          </div>
        </div>
      </div>

      <div class="glass-card">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h5 class="mb-0"><i class="bi bi-bag-check me-2 text-primary"></i>
            <%= t('recent_orders') %>
          </h5>
          <a href="/orders" class="btn btn-sm btn-outline-primary rounded-pill">
            <%= t('view_all') %>
          </a>
        </div>
        <% if (orders.length===0) { %>
          <p class="text-muted text-center py-3">
            <%= t('no_orders_yet') %>
          </p>
          <% } else { %>
            <% orders.slice(0, 5).forEach(order=> { %>
              <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                <div>
                  <span class="fw-semibold">#<%= order._id.toString().slice(-6) %></span>
                  <span class="text-muted small ms-2">
                    <%= new Date(order.createdAt).toLocaleDateString() %>
                  </span>
                </div>
                <div class="d-flex align-items-center gap-2">
                  <span class="badge bg-<%= order.orderStatus === 'delivered' ? 'success' : 'warning' %> rounded-pill">
                    <%= order.orderStatus %>
                  </span>
                  <span class="fw-bold text-primary">$<%= order.totalAmount.toFixed(2) %></span>
                  <a href="/delivery/<%= order._id %>" class="btn btn-sm btn-outline-primary rounded-pill"><i
                      class="bi bi-geo-alt"></i></a>
                </div>
              </div>
              <% }) %>
                <% } %>
      </div>
    </div>
  </div>
</div>

<style>
  .profile-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary), var(--primary-dark));
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .profile-avatar span {
    color: #fff;
    font-size: 2rem;
    font-weight: 700;
  }
</style>