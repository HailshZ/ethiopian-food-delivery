<div class="container py-4">
  <h1 class="mb-4" style="color: #078930; font-weight: 700;">
    <%= t('your_cart') %>
  </h1>

  <% if (cart.items.length===0) { %>
    <div class="text-center py-5"
      style="background: white; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05);">
      <i class="bi bi-cart-x" style="font-size: 4rem; color: #da121a;"></i>
      <h4 class="mt-3" style="color: #2c3e50;">
        <%= t('cart_empty') %>
      </h4>
      <p class="mb-4" style="color: #5d6d7e;">
        <%= t('add_some_items') %>
      </p>
      <a href="/menu" class="btn btn-primary btn-lg"
        style="background: linear-gradient(135deg, #078930, #056b24); border: none; border-radius: 50px; padding: 0.75rem 2rem;">
        <i class="bi bi-arrow-left me-2"></i>
        <%= t('continue_shopping') %>
      </a>
    </div>
    <% } else { %>
      <div class="row">
        <!-- Cart Items -->
        <div class="col-lg-8 mb-4">
          <div class="table-responsive">
            <table class="table align-middle"
              style="background: white; border-radius: 20px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.05);">
              <thead>
                <tr style="background: linear-gradient(135deg, #078930, #056b24); color: white;">
                  <th style="padding: 1rem;">
                    <%= t('item') %>
                  </th>
                  <th class="text-end">
                    <%= t('price') %>
                  </th>
                  <th class="text-center">
                    <%= t('quantity') %>
                  </th>
                  <th class="text-end">
                    <%= t('total') %>
                  </th>
                  <th class="text-center">
                    <%= t('action') %>
                  </th>
                </tr>
              </thead>
              <tbody>
                <% cart.items.forEach(item=> { %>
                  <tr>
                    <td style="padding: 1rem;">
                      <div class="d-flex align-items-center">
                        <img src="<%= item.imageUrl || 'https://via.placeholder.com/60x60?text=Food' %>"
                          style="width: 60px; height: 60px; object-fit: cover; border-radius: 10px; border: 2px solid #fcdd09; margin-right: 1rem;">
                        <div>
                          <strong style="color: #2c3e50;">
                            <%= currentLanguage==='en' ? item.name : (item.nameAm || item.name) %>
                          </strong><br>
                          <small style="color: #95a5a6;">ID: <%= item.dishId %></small>
                        </div>
                      </div>
                    </td>
                    <td class="text-end fw-bold" style="color: #078930;">
                      <%= settings.currencySymbol || 'ETB' %>
                        <%= item.price.toFixed(2) %>
                    </td>
                    <td class="text-center">
                      <form action="/cart/update/<%= item.dishId %>" method="post"
                        class="d-flex justify-content-center">
                        <input type="number" name="qty" value="<%= item.qty %>" min="1"
                          style="width: 70px; border: 2px solid #e0e0e0; border-radius: 10px; text-align: center; padding: 0.3rem;">
                        <button type="submit" class="btn btn-sm ms-1"
                          style="border: 2px solid #078930; color: #078930; border-radius: 10px;">
                          <i class="bi bi-arrow-repeat"></i>
                        </button>
                      </form>
                    </td>
                    <td class="text-end fw-bold" style="color: #da121a;">
                      <%= settings.currencySymbol || 'ETB' %>
                        <%= item.totalPrice.toFixed(2) %>
                    </td>
                    <td class="text-center">
                      <form action="/cart/remove/<%= item.dishId %>" method="post">
                        <button type="submit" class="btn btn-sm"
                          style="border: 2px solid #da121a; color: #da121a; border-radius: 10px;">
                          <i class="bi bi-trash"></i>
                        </button>
                      </form>
                    </td>
                  </tr>
                  <% }) %>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Order Summary -->
        <div class="col-lg-4">
          <div class="card" style="border: none; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.08);">
            <div class="card-body" style="padding: 1.5rem;">
              <h5
                style="color: #078930; font-weight: 700; border-bottom: 2px solid #fcdd09; padding-bottom: 0.75rem; margin-bottom: 1.5rem;">
                <i class="bi bi-receipt me-2"></i>
                <%= t('order_summary') %>
              </h5>
              <div class="d-flex justify-content-between mb-2">
                <span>
                  <%= t('subtotal') %> (<%= cart.totalQty %>
                      <%= t('items') %>):
                </span>
                <span class="fw-bold">
                  <%= settings.currencySymbol || 'ETB' %>
                    <%= cart.totalPrice.toFixed(2) %>
                </span>
              </div>
              <div class="d-flex justify-content-between mb-2">
                <span>
                  <%= t('delivery_fee') %>:
                </span>
                <span class="fw-bold text-success">Free</span>
              </div>
              <hr style="border-top: 2px dashed #e0e0e0;">
              <div class="d-flex justify-content-between mb-4">
                <span class="h5">
                  <%= t('total') %>:
                </span>
                <span class="h5" style="color: #078930;">
                  <%= settings.currencySymbol || 'ETB' %>
                    <%= cart.totalPrice.toFixed(2) %>
                </span>
              </div>
              <div class="d-grid gap-2">
                <a href="/checkout" class="btn btn-success btn-lg"
                  style="background: linear-gradient(135deg, #078930, #056b24); border: none; border-radius: 50px; padding: 0.75rem;">
                  <i class="bi bi-credit-card me-2"></i>
                  <%= t('checkout') %>
                </a>
                <a href="/menu" class="btn btn-outline-secondary"
                  style="border: 2px solid #2c3e50; color: #2c3e50; border-radius: 50px; padding: 0.75rem;">
                  <i class="bi bi-arrow-left me-2"></i>
                  <%= t('continue_shopping') %>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
      <% } %>
</div>