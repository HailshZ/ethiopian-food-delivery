<div class="container py-5">
  <h1 class="section-title text-center mb-5"><i class="bi bi-cart3 me-2"></i>
    <%= t('your_cart') %>
  </h1>

  <% if (cart.items.length===0) { %>
    <div class="empty-state">
      <i class="bi bi-cart-x"></i>
      <h4>
        <%= t('cart_empty') %>
      </h4>
      <p>
        <%= t('add_some_items') %>
      </p>
      <a href="/menu" class="btn btn-primary btn-lg rounded-pill px-5 mt-3">
        <i class="bi bi-arrow-left me-2"></i>
        <%= t('continue_shopping') %>
      </a>
    </div>
    <% } else { %>
      <div class="row g-4">
        <!-- Cart Items -->
        <div class="col-lg-8">
          <div class="glass-card" id="cart-items-container">
            <% cart.items.forEach(item=> { %>
              <div class="cart-item" data-dish-id="<%= item.dishId %>">
                <img src="<%= item.imageUrl || 'https://images.unsplash.com/photo-1604329760661-e71dc83f8f26?w=400' %>"
                  alt="<%= item.name %>" class="cart-item-img">
                <div class="cart-item-info">
                  <h6>
                    <%= currentLanguage==='en' ? item.name : (item.nameAm || item.name) %>
                  </h6>
                  <span class="cart-item-price">$<%= item.price.toFixed(2) %> each</span>
                </div>
                <div class="cart-item-qty">
                  <button class="qty-btn minus" onclick="updateCartQty('<%= item.dishId %>', <%= item.qty - 1 %>)">
                    <i class="bi bi-dash"></i>
                  </button>
                  <span class="qty-display">
                    <%= item.qty %>
                  </span>
                  <button class="qty-btn plus" onclick="updateCartQty('<%= item.dishId %>', <%= item.qty + 1 %>)">
                    <i class="bi bi-plus"></i>
                  </button>
                </div>
                <div class="cart-item-total">$<%= item.totalPrice.toFixed(2) %>
                </div>
                <button class="cart-item-remove" onclick="removeCartItem('<%= item.dishId %>')">
                  <i class="bi bi-trash3"></i>
                </button>
              </div>
              <% }) %>
          </div>
          <a href="/menu" class="btn btn-outline-secondary rounded-pill mt-3">
            <i class="bi bi-arrow-left me-2"></i>
            <%= t('continue_shopping') %>
          </a>
        </div>

        <!-- Order Summary -->
        <div class="col-lg-4">
          <div class="glass-card summary-card sticky-top" style="top: 100px;">
            <h5 class="summary-title"><i class="bi bi-receipt me-2"></i>
              <%= t('order_summary') %>
            </h5>
            <div class="summary-row">
              <span>
                <%= t('subtotal') %> (<span id="cart-qty">
                    <%= cart.totalQty %>
                  </span>
                  <%= t('items') %>)
              </span>
              <span class="fw-bold" id="cart-subtotal">$<%= cart.totalPrice.toFixed(2) %></span>
            </div>
            <div class="summary-row">
              <span>
                <%= t('delivery_fee') %>
              </span>
              <span class="text-success fw-bold">FREE</span>
            </div>
            <hr class="dashed">
            <div class="summary-row total">
              <span>
                <%= t('total') %>
              </span>
              <span id="cart-total">$<%= cart.totalPrice.toFixed(2) %></span>
            </div>
            <a href="/checkout" class="btn btn-primary w-100 rounded-pill py-3 mt-4">
              <i class="bi bi-lock-fill me-2"></i>
              <%= t('checkout') %>
            </a>
          </div>
        </div>
      </div>
      <% } %>
</div>